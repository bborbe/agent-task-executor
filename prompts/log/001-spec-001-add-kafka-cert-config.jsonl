\n656\t\t\t\t}\n657\t\t\t\t_, err := jobSpawner.SpawnJob(ctx, task, config)\n658\t\t\t\tExpect(err).To(BeNil())\n659\t\n660\t\t\t\tjobs, err := fakeClient.BatchV1().Jobs(\"test-ns\").List(ctx, metav1.ListOptions{})\n661\t\t\t\tExpect(err).To(BeNil())\n662\t\t\t\tExpect(jobs.Items).To(HaveLen(1))\n663\t\n664\t\t\t\tcontainer := jobs.Items[0].Spec.Template.Spec.Containers[0]\n665\t\t\t\tExpect(container.Resources.Requests.Cpu().String()).To(Equal(\"500m\"))\n666\t\t\t\tExpect(container.Resources.Limits.Cpu().String()).To(Equal(\"1\"))\n667\t\t\t\tExpect(container.Resources.Requests.Memory().String()).To(Equal(\"1Gi\"))\n668\t\t\t\tExpect(container.Resources.Limits.Memory().String()).To(Equal(\"2Gi\"))\n669\t\t\t\tExpect(container.Resources.Requests[corev1.ResourceEphemeralStorage]).\n670\t\t\t\t\tTo(Equal(resource.MustParse(\"2Gi\")))\n671\t\t\t\tExpect(container.Resources.Limits[corev1.ResourceEphemeralStorage]).\n672\t\t\t\t\tTo(Equal(resource.MustParse(\"4Gi\")))\n673\t\t\t})\n674\t\n675\t\t\tIt(\"uses k8s builder defaults when Resources is nil\", func() {\n676\t\t\t\ttask := lib.Task{\n677\t\t\t\t\tTaskIdentifier: lib.TaskIdentifier(\"abc-nil-resources\"),\n678\t\t\t\t\tFrontmatter: lib.TaskFrontmatter{\n679\t\t\t\t\t\t\"assignee\": \"claude\",\n680\t\t\t\t\t},\n681\t\t\t\t}\n682\t\t\t\tconfig := pkg.AgentConfiguration{\n683\t\t\t\t\tAssignee:  \"claude\",\n684\t\t\t\t\tImage:     \"my-image:latest\",\n685\t\t\t\t\tEnv:       map[string]string{},\n686\t\t\t\t\tResources: nil,\n687\t\t\t\t}\n688\t\t\t\t_, err := jobSpawner.SpawnJob(ctx, task, config)\n689\t\t\t\tExpect(err).To(BeNil())\n690\t\n691\t\t\t\tjobs, err := fakeClient.BatchV1().Jobs(\"test-ns\").List(ctx, metav1.ListOptions{})\n692\t\t\t\tExpect(err).To(BeNil())\n693\t\t\t\tExpect(jobs.Items).To(HaveLen(1))\n694\t\n695\t\t\t\tcontainer := jobs.Items[0].Spec.Template.Spec.Containers[0]\n696\t\t\t\tExpect(container.Resources.Limits.Cpu().String()).To(Equal(\"50m\"))\n697\t\t\t\tExpect(container.Resources.Requests.Cpu().String()).To(Equal(\"20m\"))\n698\t\t\t\tExpect(container.Resources.Limits.Memory().String()).To(Equal(\"50Mi\"))\n699\t\t\t\tExpect(container.Resources.Requests.Memory().String()).To(Equal(\"20Mi\"))\n700\t\t\t\t_, hasEphReq := container.Resources.Requests[corev1.ResourceEphemeralStorage]\n701\t\t\t\tExpect(hasEphReq).To(BeFalse())\n702\t\t\t\t_, hasEphLim := container.Resources.Limits[corev1.ResourceEphemeralStorage]\n703\t\t\t\tExpect(hasEphLim).To(BeFalse())\n704\t\t\t})\n705\t\n706\t\t\tIt(\"leaves CPU limit at builder default when only Requests.CPU is set\", func() {\n707\t\t\t\ttask := lib.Task{\n708\t\t\t\t\tTaskIdentifier: lib.TaskIdentifier(\"abc-one-sided\"),\n709\t\t\t\t\tFrontmatter: lib.TaskFrontmatter{\n710\t\t\t\t\t\t\"assignee\": \"claude\",\n711\t\t\t\t\t},\n712\t\t\t\t}\n713\t\t\t\tconfig := pkg.AgentConfiguration{\n714\t\t\t\t\tAssignee: \"claude\",\n715\t\t\t\t\tImage:    \"my-image:latest\",\n716\t\t\t\t\tEnv:      map[string]string{},\n717\t\t\t\t\tResources: &agentv1.AgentResources{\n718\t\t\t\t\t\tRequests: agentv1.AgentResourceList{CPU: \"500m\"},\n719\t\t\t\t\t},\n720\t\t\t\t}\n721\t\t\t\t_, err := jobSpawner.SpawnJob(ctx, task, config)\n722\t\t\t\tExpect(err).To(BeNil())\n723\t\n724\t\t\t\tjobs, err := fakeClient.BatchV1().Jobs(\"test-ns\").List(ctx, metav1.ListOptions{})\n725\t\t\t\tExpect(err).To(BeNil())\n726\t\t\t\tExpect(jobs.Items).To(HaveLen(1))\n727\t\n728\t\t\t\tcontainer := jobs.Items[0].Spec.Template.Spec.Containers[0]\n729\t\t\t\tExpect(container.Resources.Requests.Cpu().String()).To(Equal(\"500m\"))\n730\t\t\t\tExpect(container.Resources.Limits.Cpu().String()).To(Equal(\"50m\"))\n731\t\t\t})\n732\t\n733\t\t\tIt(\"stamps priorityClassName on the spawned Job when config has it set\", func() {\n734\t\t\t\ttask := lib.Task{\n735\t\t\t\t\tTaskIdentifier: lib.TaskIdentifier(\"test-task-uuid-1234\"),\n736\t\t\t\t\tFrontmatter: lib.TaskFrontmatter{\n737\t\t\t\t\t\t\"assignee\": \"claude-agent\",\n738\t\t\t\t\t},\n739\t\t