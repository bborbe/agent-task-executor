,\n\t\tbranch:                     branch,\n\t\ttopicPrefix:                topicPrefix,\n\t\tcurrentDateTimeGetter:      currentDateTimeGetter,\n\t\tjobTTLSecondsAfterFinished: jobTTLSecondsAfterFinished,\n\t\tjobKafkaClientCertSecret:   jobKafkaClientCertSecret,\n\t\tjobKafkaCaCertSecret:       jobKafkaCaCertSecret,\n\t}\n}"}}],"model":"MiniMax-M2.7-highspeed","stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":34634,"output_tokens":0,"cache_creation_input_tokens":0,"cache_read_input_tokens":23387},"context_management":null},"parent_tool_use_id":null,"session_id":"dc29c76a-8bf7-403c-aa72-7154cc3e20dc","uuid":"f51f8a16-106e-48ee-ad39-e4a54802f475"}
