{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_function_enl4rnqa1ppx_1","type":"tool_result","content":"1\t// Copyright (c) 2026 Benjamin Borbe All rights reserved.\n2\t// Use of this source code is governed by a BSD-style\n3\t// license that can be found in the LICENSE file.\n4\t\n5\tpackage spawner_test\n6\t\n7\t//go:generate go run github.com/maxbrunsfeld/counterfeiter/v6@v6.12.2 -generate\n8\t\n9\timport (\n10\t\t\"context\"\n11\t\t\"fmt\"\n12\t\t\"testing\"\n13\t\n14\t\tlib \"github.com/bborbe/agent\"\n15\t\tlibtime \"github.com/bborbe/time\"\n16\t\tlibtimetest \"github.com/bborbe/time/test\"\n17\t\t. \"github.com/onsi/ginkgo/v2\"\n18\t\t. \"github.com/onsi/gomega\"\n19\t\tbatchv1 \"k8s.io/api/batch/v1\"\n20\t\tcorev1 \"k8s.io/api/core/v1\"\n21\t\tk8serrors \"k8s.io/apimachinery/pkg/api/errors\"\n22\t\t\"k8s.io/apimachinery/pkg/api/resource\"\n23\t\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n24\t\t\"k8s.io/apimachinery/pkg/runtime\"\n25\t\t\"k8s.io/client-go/kubernetes/fake\"\n26\t\tk8stesting \"k8s.io/client-go/testing\"\n27\t\n28\t\tagentv1 \"github.com/bborbe/agent-task-executor/k8s/apis/agent.benjamin-borbe.de/v1\"\n29\t\tpkg \"github.com/bborbe/agent-task-executor/pkg\"\n30\t\t\"github.com/bborbe/agent-task-executor/pkg/spawner\"\n31\t)\n32\t\n33\tfunc TestSpawner(t *testing.T) {\n34\t\tRegisterFailHandler(Fail)\n35\t\tRunSpecs(t, \"Spawner Suite\")\n36\t}\n37\t\n38\tvar _ = Describe(\"JobSpawner\", func() {\n39\t\tvar (\n40\t\t\tctx             context.Context\n41\t\t\tfakeClient      *fake.Clientset\n42\t\t\tjobSpawner      spawner.JobSpawner\n43\t\t\tcurrentDateTime libtime.CurrentDateTime\n44\t\t)\n45\t\n46\t\tBeforeEach(func() {\n47\t\t\tctx = context.Background()\n48\t\t\tfakeClient = fake.NewClientset()\n49\t\t\tcurrentDateTime = libtime.NewCurrentDateTime()\n50\t\t\tcurrentDateTime.SetNow(libtimetest.ParseDateTime(\"2026-04-03T17:35:00Z\"))\n51\t\t\tjobSpawner = spawner.NewJobSpawner(\n52\t\t\t\tfakeClient,\n53\t\t\t\t\"test-ns\",\n54\t\t\t\t\"kafka:9092\",\n55\t\t\t\t\"develop\",\n56\t\t\t\t\"test-prefix\",\n57\t\t\t\tcurrentDateTime,\n58\t\t\t\t1800,\n59\t\t\t)\n60\t\t})\n61\t\n62\t\tDescribe(\"SpawnJob\", func() {\n63\t\t\tIt(\"creates a job with correct name and env vars\", func() {\n64\t\t\t\ttask := lib.Task{\n65\t\t\t\t\tTaskIdentifier: lib.TaskIdentifier(\"abc12345-rest-ignored\"),\n66\t\t\t\t\tFrontmatter: lib.TaskFrontmatter{\n67\t\t\t\t\t\t\"assignee\": \"claude\",\n68\t\t\t\t\t\t\"phase\":    \"planning\",\n69\t\t\t\t\t},\n70\t\t\t\t\tContent: lib.TaskContent(\"do the work\"),\n71\t\t\t\t}\n72\t\t\t\tconfig := pkg.AgentConfiguration{\n73\t\t\t\t\tAssignee: \"claude\",\n74\t\t\t\t\tImage:    \"my-image:latest\",\n75\t\t\t\t\tEnv:      map[string]string{\"GEMINI_API_KEY\": \"test-gemini-key\"},\n76\t\t\t\t}\n77\t\t\t\t_, err := jobSpawner.SpawnJob(ctx, task, config)\n78\t\t\t\tExpect(err).To(BeNil())\n79\t\n80\t\t\t\tjobs, err := fakeClient.BatchV1().Jobs(\"test-ns\").List(ctx, metav1.ListOptions{})\n81\t\t\t\tExpect(err).To(BeNil())\n82\t\t\t\tExpect(jobs.Items).To(HaveLen(1))\n83\t\n84\t\t\t\tjob := jobs.Items[0]\n85\t\t\t\tExpect(job.Name).To(Equal(\"claude-abc12345-20260403173500\"))\n86\t\t\t\tExpect(job.Namespace).To(Equal(\"test-ns\"))\n87\t\t\t\tExpect(*job.Spec.BackoffLimit).To(Equal(int32(0)))\n88\t\t\t\tExpect(job.Spec.Template.Spec.RestartPolicy).To(Equal(corev1.RestartPolicyNever))\n89\t\n90\t\t\t\tExpect(job.Spec.TTLSecondsAfterFinished).NotTo(BeNil())\n91\t\t\t\tExpect(*job.Spec.TTLSecondsAfterFinished).To(Equal(int32(1800)))\n92\t\n93\t\t\t\tExpect(job.Spec.Template.Labels).To(HaveKeyWithValue(\"app\", \"agent\"))\n94\t\t\t\tExpect(job.Spec.Template.Labels).To(HaveKey(\"component\"))\n95\t\n96\t\t\t\tExpect(job.Spec.Template.Spec.ImagePullSecrets).To(HaveLen(1))\n97\t\t\t\tExpect(job.Spec.Template.Spec.ImagePullSecrets[0].Name).To(Equal(\"docker\"))\n98\t\n99\t\t\t\tcontainer := job.Spec.Template.Spec.Containers[0]\n100\t\t\t\tExpect(container.Image).To