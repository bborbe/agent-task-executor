44\t\n145\t\t\t\tjobs, err := fakeClient.BatchV1().Jobs(\"test-ns\").List(ctx, metav1.ListOptions{})\n146\t\t\t\tExpect(err).To(BeNil())\n147\t\t\t\tExpect(jobs.Items).To(HaveLen(1))\n148\t\n149\t\t\t\tenvMap := make(map[string]string)\n150\t\t\t\tfor _, e := range jobs.Items[0].Spec.Template.Spec.Containers[0].Env {\n151\t\t\t\t\tenvMap[e.Name] = e.Value\n152\t\t\t\t}\n153\t\t\t\tExpect(envMap).To(HaveKey(\"TOPIC_PREFIX\"))\n154\t\t\t\tExpect(envMap[\"TOPIC_PREFIX\"]).To(Equal(\"\"))\n155\t\t\t})\n156\t\n157\t\t\tIt(\"propagates a non-default ttlSecondsAfterFinished to the Job spec\", func() {\n158\t\t\t\tcustomTTL := int32(60)\n159\t\t\t\tjobSpawner = spawner.NewJobSpawner(\n160\t\t\t\t\tfakeClient,\n161\t\t\t\t\t\"test-ns\",\n162\t\t\t\t\t\"kafka:9092\",\n163\t\t\t\t\t\"develop\",\n164\t\t\t\t\t\"test-prefix\",\n165\t\t\t\t\tcurrentDateTime,\n166\t\t\t\t\tcustomTTL,\n167\t\t\t\t)\n168\t\t\t\ttask := lib.Task{\n169\t\t\t\t\tTaskIdentifier: lib.TaskIdentifier(\"ttl-custom\"),\n170\t\t\t\t\tFrontmatter: lib.TaskFrontmatter{\n171\t\t\t\t\t\t\"assignee\": \"claude\",\n172\t\t\t\t\t\t\"phase\":    \"planning\",\n173\t\t\t\t\t},\n174\t\t\t\t\tContent: lib.TaskContent(\"do the work\"),\n175\t\t\t\t}\n176\t\t\t\tconfig := pkg.AgentConfiguration{\n177\t\t\t\t\tAssignee: \"claude\",\n178\t\t\t\t\tImage:    \"my-image:latest\",\n179\t\t\t\t\tEnv:      map[string]string{\"GEMINI_API_KEY\": \"test-gemini-key\"},\n180\t\t\t\t}\n181\t\t\t\t_, err := jobSpawner.SpawnJob(ctx, task, config)\n182\t\t\t\tExpect(err).To(BeNil())\n183\t\n184\t\t\t\tjobs, err := fakeClient.BatchV1().Jobs(\"test-ns\").List(ctx, metav1.ListOptions{})\n185\t\t\t\tExpect(err).To(BeNil())\n186\t\t\t\tExpect(jobs.Items).To(HaveLen(1))\n187\t\t\t\tExpect(jobs.Items[0].Spec.TTLSecondsAfterFinished).NotTo(BeNil())\n188\t\t\t\tExpect(*jobs.Items[0].Spec.TTLSecondsAfterFinished).To(Equal(customTTL))\n189\t\t\t})\n190\t\n191\t\t\tIt(\n192\t\t\t\t\"includes frontmatter delimiters and keys in TASK_CONTENT so spawned agents can parse fields like clone_url\",\n193\t\t\t\tfunc() {\n194\t\t\t\t\ttask := lib.Task{\n195\t\t\t\t\t\tTaskIdentifier: lib.TaskIdentifier(\"pr-task-uuid\"),\n196\t\t\t\t\t\tFrontmatter: lib.TaskFrontmatter{\n197\t\t\t\t\t\t\t\"assignee\":  \"pr-reviewer\",\n198\t\t\t\t\t\t\t\"phase\":     \"in_progress\",\n199\t\t\t\t\t\t\t\"clone_url\": \"https://github.com/bborbe/code-reviewer.git\",\n200\t\t\t\t\t\t\t\"ref\":       \"f82244d6abcdef\",\n201\t\t\t\t\t\t\t\"base_ref\":  \"master\",\n202\t\t\t\t\t\t},\n203\t\t\t\t\t\tContent: lib.TaskContent(\"# PR Review:\\n\\nbody here\"),\n204\t\t\t\t\t}\n205\t\t\t\t\tconfig := pkg.AgentConfiguration{\n206\t\t\t\t\t\tAssignee: \"pr-reviewer\",\n207\t\t\t\t\t\tImage:    \"pr-reviewer-agent:latest\",\n208\t\t\t\t\t\tEnv:      map[string]string{},\n209\t\t\t\t\t}\n210\t\t\t\t\t_, err := jobSpawner.SpawnJob(ctx, task, config)\n211\t\t\t\t\tExpect(err).To(BeNil())\n212\t\n213\t\t\t\t\tjobs, err := fakeClient.BatchV1().Jobs(\"test-ns\").List(ctx, metav1.ListOptions{})\n214\t\t\t\t\tExpect(err).To(BeNil())\n215\t\t\t\t\tExpect(jobs.Items).To(HaveLen(1))\n216\t\t\t\t\tcontainer := jobs.Items[0].Spec.Template.Spec.Containers[0]\n217\t\t\t\t\tenvMap := make(map[string]string)\n218\t\t\t\t\tfor _, e := range container.Env {\n219\t\t\t\t\t\tenvMap[e.Name] = e.Value\n220\t\t\t\t\t}\n221\t\t\t\t\tgot := envMap[\"TASK_CONTENT\"]\n222\t\t\t\t\t// wrapper present\n223\t\t\t\t\tExpect(got).To(HavePrefix(\"---\\n\"))\n224\t\t\t\t\tExpect(got).To(ContainSubstring(\"\\n---\\n# PR Review:\"))\n225\t\t\t\t\t// frontmatter keys propagated — these are exactly the fields the\n226\t\t\t\t\t// pr-reviewer execution step reads\n227\t\t\t\t\tExpect(\n228\t\t\t\t\t\tgot,\n229\t\t\t\t\t).To(ContainSubstring(\"clone_url: https://github.com/bborbe/code-reviewer.git\"))\n230\t\t\t\t\tExpect(got).To(ContainSubstring(\"ref: f82244d6abcdef\"))\n231\t\t\t\t\tExpect(got).To(ContainSubstring(\"base_ref: master\"))\n232\t\t\t\t\tExpect(got).To(ContainSubstring(\"assignee: pr-reviewer\"))\n233\t\t\t\t\t// body preserved\n234\t\t\t\t\tExpect(got).To(ContainSubstring(\"# PR Review:\\n\\nbody here\"))\n235\t\t\t\t},\n236\t\t\t)\n237\t\n238\t\t\tIt(\n239\t\t\t\t\"emits TASK_CONTENT that lib.ParseMarkdown round-trips back to the original frontmatter\",\n240\t\t\t\tfunc() {\n241\t\t\t\t\ttask := lib.Task{\n242\t\t\t\t\t\tTaskIdentifier: lib.TaskIdentifier(\"roundtrip-task\"),\n243\t\t\t\t\t\tFrontmatter: lib.TaskFrontmatter{\n244\t\t\t\t\t\t\t\"assignee\":  \"pr-reviewer\",\n245\t\t\t\t\t\t\t\"clone_url\": \"https://github.com/bborbe/code-reviewer.git\",\n246\t\t\t\t\t\t\t\"ref\":       \"abc123\",\n247\t\t\t\t\t\t\t\"base_ref\":  \"master\",\n248\t\t\t\t\t\t},\n249\t\t\t\t\t\tContent: lib.TaskContent(\"# Body\\n\"),\n250\t\t\t\t\t}\n251\t\t\t\t\tconfig := pkg.AgentConfiguration{Assignee: \"pr-reviewer\", Image: \"x:y\"}\n252\t\t\t\t\t_, err := jobSpawner.SpawnJob(ctx, task, config)\n253\t\t\t\t\tExpect(err).To(BeNil())\n254\t\n255\t\t\t\t\tjobs, err := fakeClient.BatchV1().Jobs(\"test-ns\").List(ctx, metav1.ListOptions{})\n256\t\t\t\t\tExpect(err).To(BeNil())\n257\t\t\t\t\tcontainer := jobs.Items[0].Spec.Template.Spec.Containers[0]\n258\t\t\t\t\tvar taskContent string\n259\t\t\t\t\tfor _, e := range container.Env {\n260\t\t\t\t\t\tif e.Name == \"TASK_CONTENT\" {\n261\t\t\t\t\t\t\ttaskContent = e.Value\n262\t\t\t\t\t\t}\n263\t\t\t\t\t}\n264\t\t\t\t\tExpect(taskContent).NotTo(BeEmpty())\n265\t\n266\t\t\t\t\tparsed, parseErr := lib.ParseMarkdown(ctx, taskContent)\n267\t\t\t\t\tExpect(parseErr).NotTo(HaveOccurred())\n268\t\t\t\t\tExpect(\n269\t\t\t\t\t\tparsed.Frontmatter,\n270\t\t\t\t\t).To(HaveKeyWithValue(\"clone_url\", \"https://github.com/bborbe/code-reviewer.git\"))\n271\t\t\t\t\tExpect(parsed.Frontmatter).To(HaveKeyWithValue(\"ref\", \"abc123\"))\n272\t\t\t\t\tExpect(parsed.Frontmatter).To(HaveKeyWithValue(\"base_ref\", \"master\"))\n273\t\t\t\t\tExpect(parsed.Frontmatter).To(HaveKeyWithValue(\"assignee\", \"pr-reviewer\"))\n274\t\t\t\t},\n275\t\t\t)\n276\t\n277\t\t\tIt(\"emits raw body without wrapper when frontmatter is empty\", func() {\n278\t\t\t\ttask := lib.Task{\n279\t\t\t\t\tTaskIdentifier: lib.TaskIdentifier(\"no-fm-task\"),\n280\t\t\t\t\tFrontmatter:    lib.TaskFrontmatter{}, // explicitly empty\n281\t\t\t\t\tContent:        lib.TaskContent(\"just a body\"),\n282\t\t\t\t}\n283\t\t\t\tconfig := pkg.AgentConfiguration{Assignee: \"claude\", Image: \"x:y\"}\n284\t\t\t\t_, err := jobSpawner.SpawnJob(ctx, task, config)\n285\t\t\t\tExpect(err).To(BeNil())\n286\t\n287\t\t\t\tjobs, err := fakeClient.BatchV1().Jobs(\"test-ns\").List(ctx, metav1.ListOptions{})\n288\t\t\t\tExpect(err).To(BeNil())\n289\t\t\t\tcontainer := jobs.Items[0].Spec.Template.Spec.Containers[0]\n290\t\t\t\tenvMap := make(map[string]string)\n291\t\t\t\tfor _, e := range container.Env {\n292\t\t\t\t\tenvMap[e.Name] = e.Value\n293\t\t\t\t}\n294\t\t\t\tExpect(envMap[\"TASK_CONTENT\"]).To(Equal(\"just a body\"))\n295\t\t\t\tExpect(envMap[\"TASK_CONTENT\"]).NotTo(ContainSubstring(\"---\"))\n296\t\t\t\tExpect(envMap[\"TASK_CONTENT\"]).NotTo(ContainSubstring(\"{}\"))\n297\t\t\t})\n298\t\n299\t\t\tIt(\"injects empty PHASE when task frontmatter has no phase\", func() {\n300\t\t\t\ttask := lib.Task{\n301\t\t\t\t\tTaskIdentifier: lib.TaskIdentifier(\"no-phase-task\"),\n302\t\t\t\t\tFrontmatter: lib.TaskFrontmatter{\n303\t\t\t\t\t\t\"assignee\": \"claude\",\n304\t\t\t\t\t},\n305\t\t\t\t\tContent: lib.TaskContent(\"do the work\"),\n306\t\t\t\t}\n307\t\t\t\tconfig := pkg.AgentConfiguration{\n308\t\t\t\t\tAssignee: \"claude\",\n309\t\t\t\t\tImage:    \"my-image:latest\",\n310\t\t\t\t\tEnv:      map[string]string{},\n311\t\t\t\t}\n312\t\t\t\t_, err := jobSpawner.SpawnJob(ctx, task, config)\n313\t\t\t\tExpect(err).To(BeNil())\n314\t\n315\t\t\t\tjobs, err := fakeClient.BatchV1().Jobs(\"test-ns\").List(ctx, metav1.ListOptions{})\n316\t\t\t\tExpect(err).To(BeNil())\n317\t\t\t\tExpect(jobs.Items).To(HaveLen(1))\n318\t\n319\t\t\t\tenvMap := make(map[string]string)\n320\t\t\t\tfor _, e := range jobs.Items[0].Spec.Template.Spec.Containers[0].Env {\n321\t\t\t\t\tenvMap[e.Name] = e.Value\n322\t\t\t\t}\n323\t\t\t\tExpect(envMap).To(HaveKey(\"PHASE\"))\n324\t\t\t\tExpect(envMap[\"PHASE\"]).To(Equal(\"\"))\n325\t\t\t})\n326\t\n327\t\t\tIt(\"sets agent.benjamin-borbe.de/task-id label on spawned job\", func() {\n328\t\t\t\ttask := lib.Task{\n329\t\t\t\t\tTaskIdentifier: lib.TaskIdentifier(\"task-uuid-label-test\"),\n330\t\t\t\t\tFrontmatter: lib.TaskFrontmatter{\n331\t\t\t\t\t\t\"assignee\": \"claude\",\n332\t\t\t\t\t},\n333\t\t\t\t}\n334\t\t\t\tconfig := pkg.AgentConfiguration{\n335\t\t\t\t\tAssignee: \"claude\",\n336\t\t\t\t\tImage:    \"my-image:latest\",\n337\t\t\t\t\tEnv:      map[string]string{},\n338\t\t\t\t}\n339\t\t\t\tjobName, err := jobSpawner.SpawnJob(ctx, task, config)\n340\t\t\t\tExpect(err).NotTo(HaveOccurred())\n341\t\t\t\tExpect(jobName).NotTo(BeEmpty())\n342\t\n343\t\t\t\tjobs, listErr := fakeClient.BatchV1().Jobs(\"test-ns\").List(ctx, metav1.ListOptions{})\n344\t\t\t\tExpect(listErr).To(BeNil())\n345\t\t\t\tExpect(jobs.Items).To(HaveLen(1))\n346\t\t\t\tExpect(\n347\t\t\t\t\tjobs.Items[0].Labels,\n348\t\t\t\t).To(HaveKeyWithValue(\"agent.benjamin-borbe.de/task-id\", string(task.TaskIdentifier)))\n349\t\t\t\tExpect(\n350\t\t\t\t\tjobs.Items[0].Spec.Template.Labels,\n351\t\t\t\t).To(HaveKeyWithValue(\"agent.benjamin-borbe.de/task-id\", string(task.TaskIdentifier)))\n352\t\t\t})\n353\t\n354\t\t\tIt(\"includes all per-agent env vars from config\", func() {\n355\t\t\t\ttask := lib.Task{\n356\t\t\t\t\tTaskIdentifier: lib.TaskIdentifier(\"abc-multi-env\"),\n357\t\t\t\t\tFrontmatter: lib.TaskFrontmatter{\n358\t\t\t\t\t\t\"assignee\": \"trade-analysis-agent\",\n359\t\t\t\t\t},\n360\t\t\t\t}\n361\t\t\t\tconfig := pkg.AgentConfiguration{\n362\t\t\t\t\tAssignee: \"trade-analysis-agent\",\n363\t\t\t\t\tImage:    \"registry/agent-trade-analysis:dev\",\n364\t\t\t\t\tEnv: map[string]string{\n365\t\t\t\t\t\t