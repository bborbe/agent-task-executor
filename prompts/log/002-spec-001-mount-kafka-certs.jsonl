{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_function_vr49r1dkmi6z_1","type":"tool_result","content":"1\t// Copyright (c) 2026 Benjamin Borbe All rights reserved.\n2\t// Use of this source code is governed by a BSD-style\n3\t// license that can be found in the LICENSE file.\n4\t\n5\tpackage spawner\n6\t\n7\timport (\n8\t\t\"context\"\n9\t\n10\t\tlib \"github.com/bborbe/agent\"\n11\t\t\"github.com/bborbe/errors\"\n12\t\tk8s \"github.com/bborbe/k8s\"\n13\t\tlibtime \"github.com/bborbe/time\"\n14\t\t\"github.com/golang/glog\"\n15\t\t\"gopkg.in/yaml.v3\"\n16\t\tbatchv1 \"k8s.io/api/batch/v1\"\n17\t\tcorev1 \"k8s.io/api/core/v1\"\n18\t\tk8serrors \"k8s.io/apimachinery/pkg/api/errors\"\n19\t\t\"k8s.io/apimachinery/pkg/api/resource\"\n20\t\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n21\t\t\"k8s.io/client-go/kubernetes\"\n22\t\n23\t\tpkg \"github.com/bborbe/agent-task-executor/pkg\"\n24\t)\n25\t\n26\t// taskIDLabelKey labels a spawned Job with the task UUID so IsJobActive\n27\t// can look it up. Must match the selector used in IsJobActive.\n28\tconst taskIDLabelKey = \"agent.benjamin-borbe.de/task-id\"\n29\t\n30\t//counterfeiter:generate -o ../../mocks/job_spawner.go --fake-name FakeJobSpawner . JobSpawner\n31\t\n32\t// JobSpawner creates a K8s Job for a task.\n33\ttype JobSpawner interface {\n34\t\t// SpawnJob creates a K8s Job for the task and returns the job name.\n35\t\t// Returns the job name even when the job already exists (idempotent).\n36\t\tSpawnJob(ctx context.Context, task lib.Task, config pkg.AgentConfiguration) (string, error)\n37\t\t// IsJobActive returns true if an active (not completed/failed) K8s Job exists\n38\t\t// for the given task identifier. Uses the agent.benjamin-borbe.de/task-id\n39\t\t// label set by SpawnJob.\n40\t\tIsJobActive(ctx context.Context, taskIdentifier lib.TaskIdentifier) (bool, error)\n41\t}\n42\t\n43\t// NewJobSpawner creates a new JobSpawner backed by the K8s batch/v1 API.\n44\t// jobTTLSecondsAfterFinished controls how long completed Job pods survive\n45\t// before Kubernetes' TTL controller garbage-collects them.\n46\t// jobKafkaClientCertSecret and jobKafkaCaCertSecret are the names of K8s secrets\n47\t// to mount into spawned Jobs for Kafka mTLS; empty strings mean no cert mounting.\n48\tfunc NewJobSpawner(\n49\t\tkubeClient kubernetes.Interface,\n50\t\tnamespace k8s.Namespace,\n51\t\tkafkaBrokers string,\n52\t\tbranch string,\n53\t\ttopicPrefix string,\n54\t\tcurrentDateTimeGetter libtime.CurrentDateTimeGetter,\n55\t\tjobTTLSecondsAfterFinished int32,\n56\t\tjobKafkaClientCertSecret string,\n57\t\tjobKafkaCaCertSecret string,\n58\t) JobSpawner {\n59\t\treturn &jobSpawner{\n60\t\t\tkubeClient:                 kubeClient,\n61\t\t\tnamespace:                  namespace,\n62\t\t\tkafkaBrokers:               kafkaBrokers,\n63\t\t\tbranch:                     branch,\n64\t\t\ttopicPrefix:                topicPrefix,\n65\t\t\tcurrentDateTimeGetter:      currentDateTimeGetter,\n66\t\t\tjobTTLSecondsAfterFinished: jobTTLSecondsAfterFinished,\n67\t\t\tjobKafkaClientCertSecret:   jobKafkaClientCertSecret,\n68\t\t\tjobKafkaCaCertSecret:       jobKafkaCaCertSecret,\n69\t\t}\n70\t}\n71\t\n72\t// jobSpawner implements JobSpawner by creating batch/v1 Jobs via the K8s client.\n73\ttype jobSpawner struct {\n74\t\tkubeClient                 kubernetes.Interface\n75\t\tnamespace                  k8s.Namespace\n76\t\tkafkaBrokers               string\n77\t\tbranch                     string\n78\t\ttopicPrefix                string\n79\t\tcurrentDateTimeGetter      libtime.CurrentDateTimeGetter\n80\t\tjobTTLSecondsAfterFinished int32\n81\t\tjobKafkaClientCertSecret   string\n82\t\tjobKafkaCaCertSecret       string\n83\t}\n84\t\n85\tfunc (s *jobSpawner) SpawnJob(\n86\t\tctx context.Context,\n87\t\ttask lib.Task,\n88\t\tconfig pkg.AgentConfiguration,\n89\t) (string, error) {\n90\t\tassignee := task.Frontmatter.Assignee().String()\n91\t\tnow := s.currentDateTimeGetter.Now()\n92\t\tjobName := jobNameFromTask(assignee, task.TaskIdentifier, now)\n93\t\n94\t\tenvBuilder, err := s.buildJobEnvBuilder(ctx, task, config)\n95\t\tif err != nil {\n96\t\t\treturn \"\", err\n97\t\t}\n98\t\n99\t\tcontainerBuilder := k8s.NewContainerBuilder()\n100\t\tcontainerBuilder.SetName(k8s.Name(\"agent\"))\n101\t\tcontainerBuilder.SetImage(config.Image)\n102\t\tcontainerBuilder.SetEnvBuilder(envBuilder)\n103\t\tapplyCPUMemoryResources(config, containerBuilder)\n104\t\n105\t\tpodSpecBuilder := k8s.NewPodSpecBuilder()\n106\t\n107\t\tif err := applyVolumeMount(ctx, config, containerBuilder, podSpecBuilder); err != nil {\n108\t\t\treturn \"\", err\n109\t\t}\n110\t\n111\t\tcontainersBuilder := k8s.NewContainersBuilder()\n112\t\tcontainersBuilder.SetContainerBuilders([]k8s.HasBuildContainer{containerBuilder})\n113\t\n114\t\tpodSpecBuilder.SetContainersBuilder(containersBuilder)\n115\t\tpodSpecBuilder.SetRestartPolicy(corev1.RestartPolicyNever)\n116\t\tpodSpecBuilder.SetImagePullSecrets([]string{imagePullSecretName(config)})\n117\t\n118\t\tobjectMetaBuilder := k8s.NewObjectMetaBuilder()\n119\t\tobjectMetaBuilder.SetName(k8s.Name(jobName))\n120\t\tobjectMetaBuilder.SetNamespace(s.namespace)\n121\t\n122\t\tjobBuilder := k8s.NewJobBuilder()\n123\t\tjobBuilder.SetObjectMetaBuild(objectMetaBuilder)\n124\t\tjobBuilder.SetPodSpecBuilder(podSpecBuilder)\n125\t\tjobBuilder.SetBackoffLimit(0)\n126\t\tjobBuilder.SetTTLSecondsAfterFinished(s.jobTTLSecondsAfterFinished)\n127\t\tjobBuilder.SetApp(\"agent\")\n128\t\tjobBuilder.SetComponent(string(task.TaskIdentifier))\n129\t\n130\t\tjob, err := jobBuilder.Build(ctx)\n131\t\tif err != nil {\n132\t\t\treturn \"\", errors.Wrapf(ctx, err, \"build job for task %s\", task.TaskIdentifier)\n133\t\t}\n134\t\n135\t\tapplyTaskIDLabel(task.TaskIdentifier, job)\n136\t\tapplySecretEnvFrom(config, job)\n137\t\tapplyEphemeralStorage(config, job)\n138\t\tif config.PriorityClassName != \"\" {\n139\t\t\tjob.Spec.Template.Spec.PriorityClassName = config.PriorityClassName\n140\t\t}\n141\t\tapplyActiveDeadlineSeconds(config, jobName, task.TaskIdentifier, job)\n142\t\n143\t\t_, err = s.kubeClient.BatchV1().\n144\t\t\tJobs(s.namespace.String()).\n145\t\t\tCreate(ctx, job, metav1.CreateOptions{})\n146\t\tif err != nil {\n147\t\t\tif k8serrors.IsAlreadyExists(err) {\n148\t\t\t\tglog.V(2).\n149\t\t\t\t\tInfof(\"job %s already exists for task %s, treating as success\", jobName, task.TaskIdentifier)\n150\t\t\t\treturn jobName, nil\n151\t\t\t}\n152\t\t\treturn \"\", errors.Wrapf(\n153\t\t\t\tctx,\n154\t\t\t\terr,\n155\t\t\t\t\"create job %s for task %s failed\",\n156\t\t\t\tjobName,\n157\t\t\t\ttask.TaskIdentifier,\n158\t\t\t)\n159\t\t}\n160\t\tglog.V(2).\n161\t\t\tInfof(\"created job %s for task %s with image %s\", jobName, task.TaskIdentifier, config.Image)\n162\t\treturn jobName, nil\n163\t}\n164\t\n165\tfunc (s *jobSpawner) IsJobActive(\n166\t\tctx context.Context,\n167\t\ttaskIdentifier lib.TaskIdentifier,\n168\t) (bool, error) {\n169\t\tlabelSelector := taskIDLabelKey + \"=\" + string(taskIdentifier)\n170\t\tjobs, err := s.kubeClient.BatchV1().Jobs(s.namespace.String()).List(ctx, metav1.ListOptions{\n171\t\t\tLabelSelector: labelSelector,\n172\t\t})\n173\t\tif err != nil {\n174\t\t\treturn false, errors.Wrapf(ctx, err, \"list jobs for task %s\", taskIdentifier)\n175\t\t}\n176\t\tfor _, job := range jobs.Items {\n177\t\t\tif job.Status.Succeeded > 0 {\n178\t\t\t\tcontinue\n179\t\t\t}\n180\t\t\tif job.Status.Failed > 0 && job.Status.Active == 0 {\n181\t\t\t\tcontinue\n182\t\t\t}\n183\t\t\treturn true, nil\n184\t\t}\n185\t\treturn false, nil\n186\t}\n187\t\n188\t// applyVolumeMount configures a PVC volume mount on the container and pod spec builders\n189\t// when config.VolumeClaim is non-empty. Returns an error if VolumeMountPath is missing.\n190\tfunc applyVolumeMount(\n191\t\tctx context.Context,\n192\t\tconfig pkg.AgentConfiguration,\n193\t\tcontainerBuilder k8s.ContainerBuilder,\n194\t\tpodSpecBuilder k8s.PodSpecBuilder,\n195\t) error {\n196\t\tif config.VolumeClaim == \"\" {\n197\t\t\treturn nil\n198\t\t}\n199\t\tif config.VolumeMountPath == \"\" {\n200\t\t\treturn errors.Errorf(ctx, \"VolumeMountPath required when VolumeClaim is set\")\n201\t\t}\n202\t\tcontainerBuilder.AddVolumeMounts(corev1.VolumeMount{\n203\t\t\tName:      \"agent-data\",\n204\t\t\tMountPath: config.VolumeMountPath,\n205\t\t})\n206\t\tpodSpecBuilder.SetVolumes([]corev1.Volume{\n207\t\t\t{\n208\t\t\t\tName: \"agent-data\",\n209\t\t\t\tVolumeSource: corev1.VolumeSource{\n210\t\t\t\t\tPersistentVolumeClaim: &corev1.PersistentVolumeClaimVolumeSource{\n211\t\t\t\t\t\tClaimName: config.VolumeClaim,\n212\t\t\t\t\t},\n213\t\t\t\t},\n214\t\t\t},\n215\t\t})\n216\t\treturn nil\n217\t}\n218\t\n219\t// imagePullSecretName returns the image pull secret name from the config,\n220\t// falling back to \"docker\" when not set.\n221\tfunc imagePullSecretName(config pkg.AgentConfiguration) string {\n222\t\tif config.ImagePullSecret != \"\" {\n223\t\t\treturn config.ImagePullSecret\n224\t\t}\n225\t\treturn \"docker\"\n226\t}\n227\t\n228\t// applyCPUMemoryResources sets CPU and memory requests/limits on the container builder\n229\t// when the corresponding config values are non-empty. Empty values leave builder defaults untouched.\n230\tfunc applyCPUMemoryResources(config pkg.AgentConfiguration, containerBuilder k8s.ContainerBuilder) {\n231\t\tif config.Resources == nil {\n232\t\t\treturn\n233\t\t}\n234\t\tif v := config.Resources.Requests.CPU; v != \"\" {\n235\t\t\tcontainerBuilder.SetCpuRequest(v)\n236\t\t}\n237\t\tif v := config.Resources.Limits.CPU; v != \"\" {\n238\t\t\tcontainerBuilder.SetCpuLimit(v)\n239\t\t}\n240\t\tif v := config.Resources.Requests.Memory; v != \"\" {\n241\t\t\tcontainerBuilder.SetMemoryRequest(v)\n242\t\t}\n243\t\tif v := config.Resources.Limits.Memory; v != \"\" {\n244\t\t\tcontainerBuilder.SetMemoryLimit(v)\n245\t\t}\n246\t}\n247\t\n248\t// applySecretEnvFrom appends an envFrom secretRef to the first container of the job\n249\t// when config.SecretName is non-empty.\n250\tfunc applySecretEnvFrom(config pkg.AgentConfiguration, job *batchv1.Job) {\n251\t\tif config.SecretName == \"\" {\n252\t\t\treturn\n253\t\t}\n254\t\tjob.Spec.Template.Spec.Containers[0].EnvFrom = append(\n255\t\t\tjob.Spec.Template.Spec.Containers[0].EnvFrom,\n256\t\t\tcorev1.EnvFromSource{\n257\t\t\t\tSecretRef: &corev1.SecretEnvSource{\n258\t\t\t\t\tLocalObjectReference: corev1.LocalObjectReference{\n259\t\t\t\t\t\tName: config.SecretName,\n260\t\t\t\t\t},\n261\t\t\t\t},\n262\t\t\t},\n263\t\t)\n264\t}\n265\t\n266\t// applyEphemeralStorage sets ephemeral-storage as Requests and/or Limits on the\n267\t// first container of the job based on config.Resources.\n268\t// Each value is applied independently — empty means \"leave unset\".\n269\t// The bborbe/k8s container builder does not expose setters for ephemeral-storage,\n270\t// so we patch the built job directly.\n271\tfunc applyEphemeralStorage(config pkg.AgentConfiguration, job *batchv1.Job) {\n272\t\tif config.Resources == nil {\n273\t\t\treturn\n274\t\t}\n275\t\tc := &job.Spec.Template.Spec.Containers[0]\n276\t\tif v := config.Resources.Requests.EphemeralStorage; v != \"\" {\n277\t\t\tif c.Resources.Requests == nil {\n278\t\t\t\tc.Resources.Requests = corev1.ResourceList{}\n279\t\t\t}\n280\t\t\tc.Resources.Requests[corev1.ResourceEphemeralStorage] = resource.MustParse(v)\n281\t\t}\n282\t\tif v := config.Resources.Limits.EphemeralStorage; v != \"\" {\n283\t\t\tif c.Resources.Limits == nil {\n284\t\t\t\tc.Resources.Limits = corev1.ResourceList{}\n285\t\t\t}\n286\t\t\tc.Resources.Limits[corev1.ResourceEphemeralStorage] = resource.MustParse(v)\n287\t\t}\n288\t}\n289\t\n290\t// applyTaskIDLabel sets the agent.benjamin-borbe.de/task-id label on the Job and its pod template\n291\t// so the job informer can look up the owning task by label selector.\n292\tfunc applyTaskIDLabel(taskID lib.TaskIdentifier, job *batchv1.Job) {\n293\t\tif job.Labels == nil {\n294\t\t\tjob.Labels = map[string]string{}\n295\t\t}\n296\t\tjob.Labels[taskIDLabelKey] = string(taskID)\n297\t\tif job.Spec.Template.Labels == nil {\n298\t\t\tjob.Spec.Template.Labels = map[string]string{}\n299\t\t}\n300\t\tjob.Spec.Template.Labels[taskIDLabelKey] = string(taskID)\n301\t}\n302\t\n303\t// applyActiveDeadlineSeconds stamps Job.Spec.ActiveDeadlineSeconds from the config's\n304\t// effective zombie job timeout so Kubernetes enforces a hard deadline on every spawned Job.\n305\tfunc applyActiveDeadlineSeconds(\n306\t\tconfig pkg.AgentConfiguration,\n307\t\tjobName string,\n308\t\ttaskID lib.TaskIdentifier,\n309\t\tjob *batchv1.Job,\n310\t) {\n311\t\tdeadline := int64(config.EffectiveZombieJobTimeoutSeconds())\n312\t\tjob.Spec.ActiveDeadlineSeconds = &deadline\n313\t\tglog.V(2).Infof(\"set activeDeadlineSeconds=%d on job %s for task %s\", deadline, jobName, taskID)\n314\t}\n315\t\n316\t// taskPhaseString returns the string value of the task's phase, or \"\" when absent.\n317\tfunc taskPhaseString(f lib.TaskFrontmatter) string {\n318\t\tif p := f.Phase(); p != nil {\n319\t\t\treturn string(*p)\n320\t\t}\n321\t\treturn \"\"\n322\t}\n323\t\n324\t// taskTypeString returns the string value of the task's task_type, or \"\" when absent.\n325\tfunc taskTypeString(f lib.TaskFrontmatter) string {\n326\t\treturn f.TaskType().String()\n327\t}\n328\t\n329\t// jobNameFromTask returns the K8s Job name for a task: \"{assignee}-{taskID8}-{YYYYMMDDHHMMSS}\".\n330\t// taskID8 is the first 8 chars of the task UUID, included to prevent name collisions\n331\t// between concurrent spawns of different tasks sharing the same assignee and second.\n332\t// If assignee is empty, \"agent\" is used as the default prefix.\n333\t// Job names are DNS-compliant (<=63 chars, [a-z0-9]([-a-z0-9]*[a-z0-9])?).\n334\t// Assignees should be short lowercase strings (e.g. \"claude\", \"backtest-agent\").\n335\tfunc jobNameFromTask(assignee string, taskID lib.TaskIdentifier, now libtime.DateTime) string {\n336\t\tif assignee == \"\" {\n337\t\t\tassignee = \"agent\"\n338\t\t}\n339\t\tid := string(taskID)\n340\t\tif len(id) > 8 {\n341\t\t\tid = id[:8]\n342\t\t}\n343\t\treturn assignee + \"-\" + id + \"-\" + now.UTC().Format(\"20060102150405\")\n344\t}\n345\t\n346\t// buildJobEnvBuilder constructs the env var set for the spawned Job's container.\n347\t// It renders the full markdown for TASK_CONTENT so agents can parse frontmatter\n348\t// fields like clone_url, ref, and base_ref.\n349\tfunc (s *jobSpawner) buildJobEnvBuilder(\n350\t\tctx context.Context,\n351\t\ttask lib.Task,\n352\t\tconfig pkg.AgentConfiguration,\n353\t) (k8s.EnvBuilder, error) {\n354\t\ttaskContent, err := renderTaskContent(ctx, task)\n355\t\tif err != nil {\n356\t\t\treturn nil, err\n357\t\t}\n358\t\tenvBuilder := k8s.NewEnvBuilder()\n359\t\tenvBuilder.Add(\"TASK_CONTENT\", taskContent)\n360\t\tenvBuilder.Add(\"TASK_ID\", string(task.TaskIdentifier))\n361\t\tenvBuilder.Add(\"KAFKA_BROKERS\", s.kafkaBrokers)\n362\t\tenvBuilder.Add(\"BRANCH\", s.branch)\n363\t\tenvBuilder.Add(\"TOPIC_PREFIX\", s.topicPrefix)\n364\t\tenvBuilder.Add(\"PHASE\", taskPhaseString(task.Frontmatter))\n365\t\tenvBuilder.Add(\"TASK_TYPE\", taskTypeString(task.Frontmatter))\n366\t\tfor key, value := range config.Env {\n367\t\t\tenvBuilder.Add(key, value)\n368\t\t}\n369\t\treturn envBuilder, nil\n370\t}\n371\t\n372\t// renderTaskContent serializes task into the markdown form an agent expects:\n373\t// \"---\\n<yaml-frontmatter>---\\n<body>\". When task.Frontmatter is empty, the\n374\t// body is returned unchanged (no empty \"{}\" wrapper).\n375\t//\n376\t// The agent side (lib.ParseMarkdown) reads frontmatter fields like\n377\t// clone_url / ref / base_ref directly from this string — keep the wrapper\n378\t// shape byte-compatible with controller/pkg/result.WriteResult.\n379\tfunc renderTaskContent(ctx context.Context, task lib.Task) (string, error) {\n380\t\tif len(task.Frontmatter) == 0 {\n381\t\t\treturn string(task.Content), nil\n382\t\t}\n383\t\tfmBytes, err := yaml.Marshal(map[string]any(task.Frontmatter))\n384\t\tif err != nil {\n385\t\t\treturn \"\", errors.Wrapf(ctx, err, \"marshal frontmatter for task %s\", task.TaskIdentifier)\n386\t\t}\n387\t\treturn \"---\\n\" + string(fmBytes) + \"---\\n\" + string(task.Content), nil\n388\t}\n389\t"}]},"parent_tool_use_id":null,"session_id":"ce5de3da-371b-4c34-9ae8-0104665b2961","uuid":"2f9d983c-16cd-40b6-9c12-aaf749b6b99f","timestamp":"2026-07-09T10:50:45.646Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/pkg/spawner/job_spawner.go","content":"// Copyright (c) 2026 Benjamin Borbe All rights reserved.\n// Use of this source code is governed by a BSD-style\n// license that can be found in the LICENSE file.\n\npackage spawner\n\nimport (\n\t\"context\"\n\n\tlib \"github.com/bborbe/agent\"\n\t\"github.com/bborbe/errors\"\n\tk8s \"github.com/bborbe/k8s\"\n\tlibtime \"github.com/bborbe/time\"\n\t\"github.com/golang/glog\"\n\t\"gopkg.in/yaml.v3\"\n\tbatchv1 \"k8s.io/api/batch/v1\"\n\tcorev1 \"k8s.io/api/core/v1\"\n\tk8serrors \"k8s.io/apimachinery/pkg/api/errors\"\n\t\"k8s.io/apimachinery/pkg/api/resource\"\n\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n\t\"k8s.io/client-go/kubernetes\"\n\n\tpkg \"github.com/bborbe/agent-task-executor/pkg\"\n)\n\n// taskIDLabelKey labels a spawned Job with the task UUID so IsJobActive\n// can look it up. Must match the selector used in IsJobActive.\nconst taskIDLabelKey = \"agent.benjamin-borbe.de/task-id\"\n\n//counterfeiter:generate -o ../../mocks/job_spawner.go --fake-name FakeJobSpawner . JobSpawner\n\n// JobSpawner creates a K8s Job for a task.\ntype JobSpawner interface {\n\t// SpawnJob creates a K8s Job for the task and returns the job name.\n\t// Returns the job name even when the job already exists (idempotent).\n\tSpawnJob(ctx context.Context, task lib.Task, config pkg.AgentConfiguration) (string, error)\n\t// IsJobActive returns true if an active (not completed/failed) K8s Job exists\n\t// for the given task identifier. Uses the agent.benjamin-borbe.de/task-id\n\t// label set by SpawnJob.\n\tIsJobActive(ctx context.Context, taskIdentifier lib.TaskIdentifier) (bool, error)\n}\n\n// NewJobSpawner creates a new JobSpawner backed by the K8s batch/v1 API.\n// jobTTLSecondsAfterFinished controls how long completed Job pods survive\n// before Kubernetes' TTL controller garbage-collects them.\n// jobKafkaClientCertSecret and jobKafkaCaCertSecret are the names of K8s secrets\n// to mount into spawned Jobs for Kafka mTLS; empty strings mean no cert mounting.\nfunc NewJobSpawner(\n\tkubeClient kubernetes.Interface,\n\tnamespace k8s.Namespace,\n\tkafkaBrokers string,\n\tbranch string,\n\ttopicPrefix string,\n\tcurrentDateTimeGetter libtime.CurrentDateTimeGetter,\n\tjobTTLSecondsAfterFinished int32,\n\tjobKafkaClientCertSecret string,\n\tjobKafkaCaCertSecret string,\n) JobSpawner {\n\treturn &jobSpawner{\n\t\tkubeClient:                 kubeClient,\n\t\tnamespace:                  namespace,\n\t\tkafkaBrokers:               kafkaBrokers,\n\t\tbranch:                     branch,\n\t\ttopicPrefix:                topicPrefix,\n\t\tcurrentDateTimeGetter:      currentDateTimeGetter,\n\t\tjobTTLSecondsAfterFinished: jobTTLSecondsAfterFinished,\n\t\tjobKafkaClientCertSecret:   jobKafkaClientCertSecret,\n\t\tjobKafkaCaCertSecret:       jobKafkaCaCertSecret,\n\t}\n}\n\n// jobSpawner implements JobSpawner by creating batch/v1 Jobs via the K8s client.\ntype jobSpawner struct {\n\tkubeClient                 kubernetes.Interface\n\tnamespace                  k8s.Namespace\n\tkafkaBrokers               string\n\tbranch                     string\n\ttopicPrefix                string\n\tcurrentDateTimeGetter      libtime.CurrentDateTimeGetter\n\tjobTTLSecondsAfterFinished int32\n\tjobKafkaClientCertSecret   string\n\tjobKafkaCaCertSecret       string\n}\n\nfunc (s *jobSpawner) SpawnJob(\n\tctx context.Context,\n\ttask lib.Task,\n\tconfig pkg.AgentConfiguration,\n) (string, error) {\n\tassignee := task.Frontmatter.Assignee().String()\n\tnow := s.currentDateTimeGetter.Now()\n\tjobName := jobNameFromTask(assignee, task.TaskIdentifier, now)\n\n\tenvBuilder, err := s.buildJobEnvBuilder(ctx, task, config)\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\n\tcontainerBuilder := k8s.NewContainerBuilder()\n\tcontainerBuilder.SetName(k8s.Name(\"agent\"))\n\tcontainerBuilder.SetImage(config.Image)\n\tcontainerBuilder.SetEnvBuilder(envBuilder)\n\tapplyCPUMemoryResources(config, containerBuilder)\n\n\tpodSpecBuilder := k8s.NewPodSpecBuilder()\n\n\tif err := applyVolumeMount(ctx, config, containerBuilder, podSpecBuilder); err != nil {\n\t\treturn \"\", err\n\t}\n\n\tcontainersBuilder := k8s.NewContainersBuilder()\n\tcontainersBuilder.SetContainerBuilders([]k8s.HasBuildContainer{containerBuilder})\n\n\tpodSpecBuilder.SetContainersBuilder(containersBuilder)\n\tpodSpecBuilder.SetRestartPolicy(corev1.RestartPolicyNever)\n\tpodSpecBuilder.SetImagePullSecrets([]string{imagePullSecretName(config)})\n\n\tobjectMetaBuilder := k8s.NewObjectMetaBuilder()\n\tobjectMetaBuilder.SetName(k8s.Name(jobName))\n\tobjectMetaBuilder.SetNamespace(s.namespace)\n\n\tjobBuilder := k8s.NewJobBuilder()\n\tjobBuilder.SetObjectMetaBuild(objectMetaBuilder)\n\tjobBuilder.SetPodSpecBuilder(podSpecBuilder)\n\tjobBuilder.SetBackoffLimit(0)\n\tjobBuilder.SetTTLSecondsAfterFinished(s.jobTTLSecondsAfterFinished)\n\tjobBuilder.SetApp(\"agent\")\n\tjobBuilder.SetComponent(string(task.TaskIdentifier))\n\n\tjob, err := jobBuilder.Build(ctx)\n\tif err != nil {\n\t\treturn \"\", errors.Wrapf(ctx, err, \"build job for task %s\", task.TaskIdentifier)\n\t}\n\n\tapplyTaskIDLabel(task.TaskIdentifier, job)\n\tapplySecretEnvFrom(config, job)\n\tapplyEphemeralStorage(config, job)\n\tif config.PriorityClassName != \"\" {\n\t\tjob.Spec.Template.Spec.PriorityClassName = config.PriorityClassName\n\t}\n\tapplyActiveDeadlineSeconds(config, jobName, task.TaskIdentifier, job)\n\n\t_, err = s.kubeClient.BatchV1().\n\t\tJobs(s.namespace.String()).\n\t\tCreate(ctx, job, metav1.CreateOptions{})\n\tif err != nil {\n\t\tif k8serrors.IsAlreadyExists(err) {\n\t\t\tglog.V(2).\n\t\t\t\tInfof(\"job %s already exists for task %s, treating as success\", jobName, task.TaskIdentifier)\n\t\t\treturn jobName, nil\n\t\t}\n\t\treturn \"\", errors.Wrapf(\n\t\t\tctx,\n\t\t\terr,\n\t\t\t\"create job %s for task %s failed\",\n\t\t\tjobName,\n\t\t\ttask.TaskIdentifier,\n\t\t)\n\t}\n\tglog.V(2).\n\t\tInfof(\"created job %s for task %s with image %s\", jobName, task.TaskIdentifier, config.Image)\n\treturn jobName, nil\n}\n\nfunc (s *jobSpawner) IsJobActive(\n\tctx context.Context,\n\ttaskIdentifier lib.TaskIdentifier,\n) (bool, error) {\n\tlabelSelector := taskIDLabelKey + \"=\" + string(taskIdentifier)\n\tjobs, err := s.kubeClient.BatchV1().Jobs(s.namespace.String()).List(ctx, metav1.ListOptions{\n\t\tLabelSelector: labelSelector,\n\t})\n\tif err != nil {\n\t\treturn false, errors.Wrapf(ctx, err, \"list jobs for task %s\", taskIdentifier)\n\t}\n\tfor _, job := range jobs.Items {\n\t\tif job.Status.Succeeded > 0 {\n\t\t\tcontinue\n\t\t}\n\t\tif job.Status.Failed > 0 && job.Status.Active == 0 {\n\t\t\tcontinue\n\t\t}\n\t\treturn true, nil\n\t}\n\treturn false, nil\n}\n\n// applyVolumeMount configures a PVC volume mount on the container and pod spec builders\n// when config.VolumeClaim is non-empty. Returns an error if VolumeMountPath is missing.\nfunc applyVolumeMount(\n\tctx context.Context,\n\tconfig pkg.AgentConfiguration,\n\tcontainerBuilder k8s.ContainerBuilder,\n\tpodSpecBuilder k8s.PodSpecBuilder,\n) error {\n\tif config.VolumeClaim == \"\" {\n\t\treturn nil\n\t}\n\tif config.VolumeMountPath == \"\" {\n\t\treturn errors.Errorf(ctx, \"VolumeMountPath required when VolumeClaim is set\")\n\t}\n\tcontainerBuilder.AddVolumeMounts(corev1.VolumeMount{\n\t\tName:      \"agent-data\",\n\t\tMountPath: config.VolumeMountPath,\n\t})\n\tpodSpecBuilder.SetVolumes([]corev1.Volume{\n\t\t{\n\t\t\tName: \"agent-data\",\n\t\t\tVolumeSource: corev1.VolumeSource{\n\t\t\t\tPersistentVolumeClaim: &corev1.PersistentVolumeClaimVolumeSource{\n\t\t\t\t\tClaimName: config.VolumeClaim,\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t})\n\treturn nil\n}\n\n// imagePullSecretName returns the image pull secret name from the config,\n// falling back to \"docker\" when not set.\nfunc imagePullSecretName(config pkg.AgentConfiguration) string {\n\tif config.ImagePullSecret != \"\" {\n\t\treturn config.ImagePullSecret\n\t}\n\treturn \"docker\"\n}\n\n// applyCPUMemoryResources sets CPU and memory requests/limits on the container builder\n// when the corresponding config values are non-empty. Empty values leave builder defaults untouched.\nfunc applyCPUMemoryResources(config pkg.AgentConfiguration, containerBuilder k8s.ContainerBuilder) {\n\tif config.Resources == nil {\n\t\treturn\n\t}\n\tif v := config.Resources.Requests.CPU; v != \"\" {\n\t\tcontainerBuilder.SetCpuRequest(v)\n\t}\n\tif v := config.Resources.Limits.CPU; v != \"\" {\n\t\tcontainerBuilder.SetCpuLimit(v)\n\t}\n\tif v := config.Resources.Requests.Memory; v != \"\" {\n\t\tcontainerBuilder.SetMemoryRequest(v)\n\t}\n\tif v := config.Resources.Limits.Memory; v != \"\" {\n\t\tcontainerBuilder.SetMemoryLimit(v)\n\t}\n}\n\n// applySecretEnvFrom appends an envFrom secretRef to the first container of the job\n// when config.SecretName is non-empty.\nfunc applySecretEnvFrom(config pkg.AgentConfiguration, job *batchv1.Job) {\n\tif config.SecretName == \"\" {\n\t\treturn\n\t}\n\tjob.Spec.Template.Spec.Containers[0].EnvFrom = append(\n\t\tjob.Spec.Template.Spec.Containers[0].EnvFrom,\n\t\tcorev1.EnvFromSource{\n\t\t\tSecretRef: &corev1.SecretEnvSource{\n\t\t\t\tLocalObjectReference: corev1.LocalObjectReference{\n\t\t\t\t\tName: config.SecretName,\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t)\n}\n\n// applyEphemeralStorage sets ephemeral-storage as Requests and/or Limits on the\n// first container of the job based on config.Resources.\n// Each value is applied independently — empty means \"leave unset\".\n// The bborbe/k8s container builder does not expose setters for ephemeral-storage,\n// so we patch the built job directly.\nfunc applyEphemeralStorage(config pkg.AgentConfiguration, job *batchv1.Job) {\n\tif config.Resources == nil {\n\t\treturn\n\t}\n\tc := &job.Spec.Template.Spec.Containers[0]\n\tif v := config.Resources.Requests.EphemeralStorage; v != \"\" {\n\t\tif c.Resources.Requests == nil {\n\t\t\tc.Resources.Requests = corev1.ResourceList{}\n\t\t}\n\t\tc.Resources.Requests[corev1.ResourceEphemeralStorage] = resource.MustParse(v)\n\t}\n\tif v := config.Resources.Limits.EphemeralStorage; v != \"\" {\n\t\tif c.Resources.Limits == nil {\n\t\t\tc.Resources.Limits = corev1.ResourceList{}\n\t\t}\n\t\tc.Resources.Limits[corev1.ResourceEphemeralStorage] = resource.MustParse(v)\n\t}\n}\n\n// applyTaskIDLabel sets the agent.benjamin-borbe.de/task-id label on the Job and its pod template\n// so the job informer can look up the owning task by label selector.\nfunc applyTaskIDLabel(taskID lib.TaskIdentifier, job *batchv1.Job) {\n\tif job.Labels == nil {\n\t\tjob.Labels = map[string]string{}\n\t}\n\tjob.Labels[taskIDLabelKey] = string(taskID)\n\tif job.Spec.Template.Labels == nil {\n\t\tjob.Spec.Template.Labels = map[string]string{}\n\t}\n\tjob.Spec.Template.Labels[taskIDLabelKey] = string(taskID)\n}\n\n// applyActiveDeadlineSeconds stamps Job.Spec.ActiveDeadlineSeconds from the config's\n// effective zombie job timeout so Kubernetes enforces a hard deadline on every spawned Job.\nfunc applyActiveDeadlineSeconds(\n\tconfig pkg.AgentConfiguration,\n\tjobName string,\n\ttaskID lib.TaskIdentifier,\n\tjob *batchv1.Job,\n) {\n\tdeadline := int64(config.EffectiveZombieJobTimeoutSeconds())\n\tjob.Spec.ActiveDeadlineSeconds = &deadline\n\tglog.V(2).Infof(\"set activeDeadlineSeconds=%d on job %s for task %s\", deadline, jobName, taskID)\n}\n\n// taskPhaseString returns the string value of the task's phase, or \"\" when absent.\nfunc taskPhaseString(f lib.TaskFrontmatter) string {\n\tif p := f.Phase(); p != nil {\n\t\treturn string(*p)\n\t}\n\treturn \"\"\n}\n\n// taskTypeString returns the string value of the task's task_type, or \"\" when absent.\nfunc taskTypeString(f lib.TaskFrontmatter) string {\n\treturn f.TaskType().String()\n}\n\n// jobNameFromTask returns the K8s Job name for a task: \"{assignee}-{taskID8}-{YYYYMMDDHHMMSS}\".\n// taskID8 is the first 8 chars of the task UUID, included to prevent name collisions\n// between concurrent spawns of different tasks sharing the same assignee and second.\n// If assignee is empty, \"agent\" is used as the default prefix.\n// Job names are DNS-compliant (<=63 chars, [a-z0-9]([-a-z0-9]*[a-z0-9])?).\n// Assignees should be short lowercase strings (e.g. \"claude\", \"backtest-agent\").\nfunc jobNameFromTask(assignee string, taskID lib.TaskIdentifier, now libtime.DateTime) string {\n\tif assignee == \"\" {\n\t\tassignee = \"agent\"\n\t}\n\tid := string(taskID)\n\tif len(id) > 8 {\n\t\tid = id[:8]\n\t}\n\treturn assignee + \"-\" + id + \"-\" + now.UTC().Format(\"20060102150405\")\n}\n\n// buildJobEnvBuilder constructs the env var set for the spawned Job's container.\n// It renders the full markdown for TASK_CONTENT so agents can parse frontmatter\n// fields like clone_url, ref, and base_ref.\nfunc (s *jobSpawner) buildJobEnvBuilder(\n\tctx context.Context,\n\ttask lib.Task,\n\tconfig pkg.AgentConfiguration,\n) (k8s.EnvBuilder, error) {\n\ttaskContent, err := renderTaskContent(ctx, task)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tenvBuilder := k8s.NewEnvBuilder()\n\tenvBuilder.Add(\"TASK_CONTENT\", taskContent)\n\tenvBuilder.Add(\"TASK_ID\", string(task.TaskIdentifier))\n\tenvBuilder.Add(\"KAFKA_BROKERS\", s.kafkaBrokers)\n\tenvBuilder.Add(\"BRANCH\", s.branch)\n\tenvBuilder.Add(\"TOPIC_PREFIX\", s.topicPrefix)\n\tenvBuilder.Add(\"PHASE\", taskPhaseString(task.Frontmatter))\n\tenvBuilder.Add(\"TASK_TYPE\", taskTypeString(task.Frontmatter))\n\tfor key, value := range config.Env {\n\t\tenvBuilder.Add(key, value)\n\t}\n\treturn envBuilder, nil\n}\n\n// renderTaskContent serializes task into the markdown form an agent expects:\n// \"---\\n<yaml-frontmatter>---\\n<body>\". When task.Frontmatter is empty, the\n// body is returned unchanged (no empty \"{}\" wrapper).\n//\n// The agent side (lib.ParseMarkdown) reads frontmatter fields like\n// clone_url / ref / base_ref directly from this string — keep the wrapper\n// shape byte-compatible with controller/pkg/result.WriteResult.\nfunc renderTaskContent(ctx context.Context, task lib.Task) (string, error) {\n\tif len(task.Frontmatter) == 0 {\n\t\treturn string(task.Content), nil\n\t}\n\tfmBytes, err := yaml.Marshal(map[string]any(task.Frontmatter))\n\tif err != nil {\n\t\treturn \"\", errors.Wrapf(ctx, err, \"marshal frontmatter for task %s\", task.TaskIdentifier)\n\t}\n\treturn \"---\\n\" + string(fmBytes) + \"---\\n\" + string(task.Content), nil\n}\n","numLines":389,"startLine":1,"totalLines":389}}}
