n1093\t\n1094\t\t// Regression guard: SpawnJob and IsJobActive must agree on the label key used\n1095\t\t// to identify a Job. A mismatch causes the executor to treat a freshly-spawned\n1096\t\t// Job as \"no active job\" and respawn another every poll cycle.\n1097\t\tDescribe(\"SpawnJob + IsJobActive label contract\", func() {\n1098\t\t\tIt(\"IsJobActive returns true for a Job just spawned via SpawnJob (same taskID)\", func() {\n1099\t\t\t\ttaskID := lib.TaskIdentifier(\"e2e-tid-contract-1\")\n1100\t\t\t\ttask := lib.Task{\n1101\t\t\t\t\tTaskIdentifier: taskID,\n1102\t\t\t\t\tFrontmatter:    lib.TaskFrontmatter{\"assignee\": \"claude\"},\n1103\t\t\t\t\tContent:        lib.TaskContent(\"do the work\"),\n1104\t\t\t\t}\n1105\t\t\t\tconfig := pkg.AgentConfiguration{\n1106\t\t\t\t\tAssignee: \"claude\",\n1107\t\t\t\t\tImage:    \"my-image:latest\",\n1108\t\t\t\t}\n1109\t\n1110\t\t\t\t_, err := jobSpawner.SpawnJob(ctx, task, config)\n1111\t\t\t\tExpect(err).To(BeNil())\n1112\t\n1113\t\t\t\tactive, err := jobSpawner.IsJobActive(ctx, taskID)\n1114\t\t\t\tExpect(err).To(BeNil())\n1115\t\t\t\tExpect(active).\n1116\t\t\t\t\tTo(BeTrue(), \"IsJobActive must recognise the Job that SpawnJob just created\")\n1117\t\t\t})\n1118\t\n1119\t\t\tIt(\"IsJobActive returns false for a different taskID than the one spawned\", func() {\n1120\t\t\t\tspawned := lib.TaskIdentifier(\"e2e-tid-contract-2\")\n1121\t\t\t\tother := lib.TaskIdentifier(\"e2e-tid-contract-other\")\n1122\t\t\t\ttask := lib.Task{\n1123\t\t\t\t\tTaskIdentifier: spawned,\n1124\t\t\t\t\tFrontmatter:    lib.TaskFrontmatter{\"assignee\": \"claude\"},\n1125\t\t\t\t}\n1126\t\t\t\t_, err := jobSpawner.SpawnJob(ctx, task, pkg.AgentConfiguration{\n1127\t\t\t\t\tAssignee: \"claude\", Image: \"my-image:latest\",\n1128\t\t\t\t})\n1129\t\t\t\tExpect(err).To(BeNil())\n1130\t\n1131\t\t\t\tactive, err := jobSpawner.IsJobActive(ctx, other)\n1132\t\t\t\tExpect(err).To(BeNil())\n1133\t\t\t\tExpect(active).\n1134\t\t\t\t\tTo(BeFalse(), \"IsJobActive must not match a different task's spawned Job\")\n1135\t\t\t})\n1136\t\t})\n1137\t\n1138\t\tDescribe(\"applyTaskIDLabel\", func() {\n1139\t\t\tIt(\"creates new Labels map when job.Labels is nil (via Create reactor)\", func() {\n1140\t\t\t\t// Use a Create reactor to capture the job at the moment of creation.\n1141\t\t\t\t// applyTaskIDLabel is called BEFORE the K8s Create call, so the\n1142\t\t\t\t// captured job will have the labels already set.\n1143\t\t\t\tvar capturedJob *batchv1.Job\n1144\t\t\t\tfakeClient.PrependReactor(\n1145\t\t\t\t\t\"create\",\n1146\t\t\t\t\t\"jobs\",\n1147\t\t\t\t\tfunc(action k8stesting.Action) (bool, runtime.Object, error) {\n1148\t\t\t\t\t\tcreateAction, ok := action.(k8stesting.CreateAction)\n1149\t\t\t\t\t\tif !ok {\n1150\t\t\t\t\t\t\treturn false, nil, nil\n1151\t\t\t\t\t\t}\n1152\t\t\t\t\t\tcapturedJob, ok = createAction.GetObject().(*batchv1.Job)\n1153\t\t\t\t\t\tif !ok {\n1154\t\t\t\t\t\t\treturn false, nil, nil\n1155\t\t\t\t\t\t}\n1156\t\t\t\t\t\treturn false, nil, nil // pass through to fake client\n1157\t\t\t\t\t},\n1158\t\t\t\t)\n1159\t\t\t\ttask := lib.Task{\n1160\t\t\t\t\tTaskIdentifier: lib.TaskIdentifier(\"nil-labels-task\"),\n1161\t\t\t\t\tFrontmatter:    lib.TaskFrontmatter{\"assignee\": \"claude\"},\n1162\t\t\t\t}\n1163\t\t\t\t_, err := jobSpawner.SpawnJob(ctx, task, pkg.AgentConfiguration{\n1164\t\t\t\t\tAssignee: \"claude\", Image: \"my-image:latest\",\n1165\t\t\t\t})\n1166\t\t\t\tExpect(err).To(BeNil())\n1167\t\t\t\tExpect(capturedJob).NotTo(BeNil())\n1168\t\t\t\tExpect(capturedJob.Labels).NotTo(BeNil())\n1169\t\t\t\tExpect(\n1170\t\t\t\t\tcapturedJob.Labels[\"agent.benjamin-borbe.de/task-id\"],\n1171\t\t\t\t).To(Equal(\"nil-labels-task\"))\n1172\t\t\t\tExpect(capturedJob.Spec.Template.Labels).NotTo(BeNil())\n1173\t\t\t\tExpect(\n1174\t\t\t\t\tcapturedJob.Spec.Template.Labels[\"agent.benjamin-borbe.de/task-id\"],\n1175\t\t\t\t).To(Equal(\"nil-labels-task\"))\n1176\t\t\t})\n1177\t\t})\n1178\t})\n1179\t"}]},"p