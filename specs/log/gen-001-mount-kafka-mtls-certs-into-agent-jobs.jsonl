n472\t\t\t\tjobs, err := fakeClient.BatchV1().Jobs(\"test-ns\").List(ctx, metav1.ListOptions{})\n473\t\t\t\tExpect(err).To(BeNil())\n474\t\t\t\tExpect(jobs.Items).To(HaveLen(1))\n475\t\n476\t\t\t\tjob := jobs.Items[0]\n477\t\t\t\tExpect(job.Spec.Template.Spec.Volumes).To(HaveLen(1))\n478\t\t\t\tExpect(job.Spec.Template.Spec.Volumes[0].Name).To(Equal(\"agent-data\"))\n479\t\t\t\tExpect(job.Spec.Template.Spec.Volumes[0].PersistentVolumeClaim).NotTo(BeNil())\n480\t\t\t\tExpect(\n481\t\t\t\t\tjob.Spec.Template.Spec.Volumes[0].PersistentVolumeClaim.ClaimName,\n482\t\t\t\t).To(Equal(\"agent-claude-pvc\"))\n483\t\n484\t\t\t\tcontainer := job.Spec.Template.Spec.Containers[0]\n485\t\t\t\tExpect(container.VolumeMounts).To(HaveLen(1))\n486\t\t\t\tExpect(container.VolumeMounts[0].Name).To(Equal(\"agent-data\"))\n487\t\t\t\tExpect(container.VolumeMounts[0].MountPath).To(Equal(\"/data\"))\n488\t\t\t})\n489\t\n490\t\t\tIt(\"has no volumes when VolumeClaim is empty\", func() {\n491\t\t\t\ttask := lib.Task{\n492\t\t\t\t\tTaskIdentifier: lib.TaskIdentifier(\"abc-no-pvc\"),\n493\t\t\t\t\tFrontmatter: lib.TaskFrontmatter{\n494\t\t\t\t\t\t\"assignee\": \"claude\",\n495\t\t\t\t\t},\n496\t\t\t\t}\n497\t\t\t\tconfig := pkg.AgentConfiguration{\n498\t\t\t\t\tAssignee: \"claude\",\n499\t\t\t\t\tImage:    \"my-image:latest\",\n500\t\t\t\t\tEnv:      map[string]string{},\n501\t\t\t\t}\n502\t\t\t\t_, err := jobSpawner.SpawnJob(ctx, task, config)\n503\t\t\t\tExpect(err).To(BeNil())\n504\t\n505\t\t\t\tjobs, err := fakeClient.BatchV1().Jobs(\"test-ns\").List(ctx, metav1.ListOptions{})\n506\t\t\t\tExpect(err).To(BeNil())\n507\t\t\t\tExpect(jobs.Items).To(HaveLen(1))\n508\t\n509\t\t\t\tjob := jobs.Items[0]\n510\t\t\t\tExpect(job.Spec.Template.Spec.Volumes).To(BeEmpty())\n511\t\t\t\tExpect(job.Spec.Template.Spec.Containers[0].VolumeMounts).To(BeEmpty())\n512\t\t\t})\n513\t\n514\t\t\tIt(\"returns error when VolumeClaim is set but VolumeMountPath is empty\", func() {\n515\t\t\t\ttask := lib.Task{\n516\t