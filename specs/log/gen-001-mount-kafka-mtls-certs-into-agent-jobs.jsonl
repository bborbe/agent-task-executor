t\tbranch base.Branch,\n98\t\ttopicPrefix base.TopicPrefix,\n99\t\tkubeClient kubernetes.Interface,\n100\t\tnamespace libk8s.Namespace,\n101\t\tkafkaBrokers string,\n102\t\tresolver pkg.ConfigResolver,\n103\t\tlogSamplerFactory log.SamplerFactory,\n104\t\tcurrentDateTimeGetter libtime.CurrentDateTimeGetter,\n105\t\tresultPublisher pkg.ResultPublisher,\n106\t\ttaskStore *pkg.TaskStore,\n107\t\tjobTTLSecondsAfterFinished int32,\n108\t) (libkafka.Consumer, handler.TaskEventHandler) {\n109\t\tjobSpawner := spawner.NewJobSpawner(\n110\t\t\tkubeClient,\n111\t\t\tnamespace,\n112\t\t\tkafkaBrokers,\n113\t\t\tstring(branch),\n114\t\t\tstring(topicPrefix),\n115\t\t\tcurrentDateTimeGetter,\n116\t\t\tjobTTLSecondsAfterFinished,\n117\t\t)\n118\t\ttaskEventHandler := handler.NewTaskEventHandler(\n119\t\t\tjobSpawner,\n120\t\t\tbranch,\n121\t\t\tresolver,\n122\t\t\tresultPublisher,\n123\t\t\ttaskStore,\n124\t\t\tcurrentDateTimeGetter,\n125\t\t)\n126\t\ttopic := lib.TaskV1SchemaID.EventTopic(topicPrefix)\n127\t\toffsetManager := libkafka.NewSaramaOffsetManager(\n128\t\t\tsaramaClient,\n129\t\t\tlibkafka.Group(\"agent-task-executor\"),\n130\t\t\tlibkafka.OffsetOldest,\n131\t\t\tlibkafka.OffsetOldest,\n132\t\t)\n133\t\treturn libkafka.NewOffsetConsumerHighwaterMarks(\n134\t\t\tsaramaClient,\n135\t\t\ttopic,\n136\t\t\toffsetManager,\n137\t\t\ttaskEventHandler,\n138\t\t\trun.NewTrigger(),\n139\t\t\tlogSamplerFactory,\n140\t\t), taskEventHandler\n141\t}\n142\t\n143\t// CreateHealthcheckRunner creates the healthcheck runner shared between the cron path and the\n144\t// HTTP trigger path. Callers must pass the same instance to both CreateHealthcheckCron and\n145\t// the HTTP handler so probe behavior is identical regardless of invocation path.\n146\tfunc CreateHealthcheckRunner(\n147\t\tconfigProvider pkg.EventHandlerConfig,\n148\t\tsyncProducer libkafka.SyncProducer,\n149\t\ttopicPrefix base.TopicPrefix,\n150\t\tbranch base.Branch,\n151\t) probe.HealthcheckRunner {\n152\t\tsender := cdb.NewCommandObjectSender(syncProducer, topicPrefix, log.DefaultSamplerFactory)\n153\t\tpublisher := probe.NewCommandPublisher(sender)\n154\t\treturn probe.NewHealthcheckRunner(configProvider, publisher, branch)\n155\t}\n156\t\n157\t// CreateHealthcheckCron wraps the given runner in a cron scheduler. Pass the runner returned by\n158\t// CreateHealthcheckRunner so the cron and the HTTP handler share the same instance.\n159\tfunc CreateHealthcheckCron(\n160\t\texpression libcron.Expression,\n161\t\trunner probe.HealthcheckRunner,\n162\t) pkg.CronScheduler {\n163\t\treturn libcron.NewExpressionCron(expression, runner)\n164\t}\n165\t"}]},"parent_tool_use_id":"call_function_iceqd3zlr1k8_1","session_id":"2797b87b-ab8a-4cea-b290-55a29e5d469e","uuid":"0239182c-4335-4811-b99e-a81ac47913e7","timestamp":"2026-07-09T10:42:19.577Z","subagent_type":"dark-factory:prompt-auditor","task_description":"Audit prompt 1 - kafka cert config"}
