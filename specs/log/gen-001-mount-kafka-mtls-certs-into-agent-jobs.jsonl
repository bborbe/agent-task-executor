{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01X5DcsQZCUweCygzM3EUw34","type":"tool_result","content":"1\t// Copyright (c) 2026 Benjamin Borbe All rights reserved.\n2\t// Use of this source code is governed by a BSD-style\n3\t// license that can be found in the LICENSE file.\n4\t\n5\tpackage main\n6\t\n7\timport (\n8\t\t\"context\"\n9\t\t\"os\"\n10\t\t\"time\"\n11\t\n12\t\t\"github.com/bborbe/cqrs/base\"\n13\t\tlibcron \"github.com/bborbe/cron\"\n14\t\t\"github.com/bborbe/errors\"\n15\t\tlibhttp \"github.com/bborbe/http\"\n16\t\tlibk8s \"github.com/bborbe/k8s\"\n17\t\tlibkafka \"github.com/bborbe/kafka\"\n18\t\t\"github.com/bborbe/log\"\n19\t\tlibmetrics \"github.com/bborbe/metrics\"\n20\t\t\"github.com/bborbe/run\"\n21\t\tlibsentry \"github.com/bborbe/sentry\"\n22\t\t\"github.com/bborbe/service\"\n23\t\tlibtime \"github.com/bborbe/time\"\n24\t\t\"github.com/golang/glog\"\n25\t\t\"github.com/gorilla/mux\"\n26\t\t\"github.com/prometheus/client_golang/prometheus/promhttp\"\n27\t\t\"k8s.io/client-go/kubernetes\"\n28\t\t\"k8s.io/client-go/rest\"\n29\t\n30\t\t\"github.com/bborbe/agent-task-executor/pkg\"\n31\t\t\"github.com/bborbe/agent-task-executor/pkg/factory\"\n32\t\t\"github.com/bborbe/agent-task-executor/pkg/handler\"\n33\t\t\"github.com/bborbe/agent-task-executor/pkg/probe\"\n34\t)\n35\t\n36\tfunc main() {\n37\t\tapp := &application{}\n38\t\tos.Exit(service.Main(context.Background(), app, &app.SentryDSN, &app.SentryProxy))\n39\t}\n40\t\n41\ttype application struct {\n42\t\tSentryDSN                  string            `required:\"true\"  arg:\"sentry-dsn\"                     env:\"SENTRY_DSN\"                     usage:\"SentryDSN\"                                                                             display:\"length\"`\n43\t\tSentryProxy                string            `required:\"false\" arg:\"sentry-proxy\"                   env:\"SENTRY_PROXY\"                   usage:\"Sentry Proxy\"`\n44\t\tListen                     string            `required:\"true\"  arg:\"listen\"                         env:\"LISTEN\"                         usage:\"address to listen to\"`\n45\t\tKafkaBrokers               string            `required:\"true\"  arg:\"kafka-brokers\"                  env:\"KAFKA_BROKERS\"                  usage:\"comma-separated Kafka broker addresses\"`\n46\t\tBranch                     base.Branch       `required:\"true\"  arg:\"branch\"                         env:\"BRANCH\"                         usage:\"Kafka topic prefix branch (develop/live)\"`\n47\t\tTopicPrefix                base.TopicPrefix  `required:\"false\" arg:\"topic-prefix\"                   env:\"TOPIC_PREFIX\"                   usage:\"Explicit Kafka topic prefix; empty means unprefixed topics\"`\n48\t\tNamespace                  libk8s.Namespace  `required:\"true\"  arg:\"namespace\"                      env:\"NAMESPACE\"                      usage:\"K8s namespace to spawn Jobs in\"`\n49\t\tBuildGitVersion            string            `required:\"false\" arg:\"build-git-version\"              env:\"BUILD_GIT_VERSION\"              usage:\"Build Git version (git describe --tags --always --dirty)\"                                               default:\"dev\"`\n50\t\tBuildGitCommit             string            `required:\"false\" arg:\"build-git-commit\"               env:\"BUILD_GIT_COMMIT\"               usage:\"Build Git commit hash\"                                                                                  default:\"none\"`\n51\t\tBuildDate                  *libtime.DateTime `required:\"false\" arg:\"build-date\"                     env:\"BUILD_DATE\"                     usage:\"Build timestamp (RFC3339)\"`\n52\t\tHealthcheckCronExpression  string            `required:\"true\"  arg:\"healthcheck-cron-expression\"    env:\"HEALTHCHECK_CRON_EXPRESSION\"    usage:\"Cron expression for agent liveness health checks\"                                                       default:\"0 0 8 * * 1\"`\n53\t\tJobTTLSecondsAfterFinished int32             `required:\"false\" arg:\"job-ttl-seconds-after-finished\" env:\"JOB_TTL_SECONDS_AFTER_FINISHED\" usage:\"K8s Job TTL after completion (seconds) â€” completed Job pods are GCed after this delay\"                  default:\"1800\"`\n54\t}\n55\t\n56\t//nolint:funlen // Initialization sequence; wiring is linear with no branching.\n57\tfunc (a *application) Run(ctx context.Context, sentryClient libsentry.Client) error {\n58\t\tlibmetrics.NewBuildInfoMetrics().SetBuildInfo(a.BuildGitVersion, a.BuildGitCommit, a.BuildDate)\n59\t\tglog.V(1).\n60\t\t\tInfof(\"agent-task-executor started version=%s commit=%s\", a.BuildGitVersion, a.BuildGitCommit)\n61\t\n62\t\tif a.JobTTLSecondsAfterFinished < 0 {\n63\t\t\treturn errors.Errorf(\n64\t\t\t\tctx,\n65\t\t\t\t\"job-ttl-seconds-after-finished must be >= 0 (0 deletes immediately), got %d\",\n66\t\t\t\ta.JobTTLSecondsAfterFinished,\n67\t\t\t)\n68\t\t}\n69\t\n70\t\tkubeConfig, err := rest.InClusterConfig()\n71\t\tif err != nil {\n72\t\t\treturn errors.Wrapf(ctx, err, \"get in-cluster k8s config\")\n73\t\t}\n74\t\tkubeClient, err := kubernetes.NewForConfig(kubeConfig)\n75\t\tif err != nil {\n76\t\t\treturn errors.Wrapf(ctx, err, \"create k8s client\")\n77\t\t}\n78\t\n79\t\tconnector := factory.CreateK8sConnector(kubeConfig)\n80\t\tif err := connector.SetupCustomResourceDefinition(ctx); err != nil {\n81\t\t\treturn errors.Wrapf(ctx, err, \"setup Config CRD\")\n82\t\t}\n83\t\teventHandlerConfig := factory.CreateEventHandlerConfig()\n84\t\tresourceEventHandler := factory.CreateResourceEventHandlerConfig(\n85\t\t\tctx,\n86\t\t\teventHandlerConfig,\n87\t\t)\n88\t\tresolver := factory.CreateConfigResolver(eventHandlerConfig, a.Branch)\n89\t\n90\t\tsaramaClient, err := libkafka.CreateSaramaClient(\n91\t\t\tctx,\n92\t\t\tlibkafka.ParseBrokersFromString(a.KafkaBrokers),\n93\t\t)\n94\t\tif err != nil {\n95\t\t\treturn errors.Wrapf(ctx, err, \"create sarama client\")\n96\t\t}\n97\t\tdefer saramaClient