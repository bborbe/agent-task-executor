{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CNdciB1TNrA9rNrWMVDZ9G","type":"tool_result","content":"1\t// Copyright (c) 2026 Benjamin Borbe All rights reserved.\n2\t// Use of this source code is governed by a BSD-style\n3\t// license that can be found in the LICENSE file.\n4\t\n5\tpackage spawner\n6\t\n7\timport (\n8\t\t\"context\"\n9\t\n10\t\tlib \"github.com/bborbe/agent\"\n11\t\t\"github.com/bborbe/errors\"\n12\t\tk8s \"github.com/bborbe/k8s\"\n13\t\tlibtime \"github.com/bborbe/time\"\n14\t\t\"github.com/golang/glog\"\n15\t\t\"gopkg.in/yaml.v3\"\n16\t\tbatchv1 \"k8s.io/api/batch/v1\"\n17\t\tcorev1 \"k8s.io/api/core/v1\"\n18\t\tk8serrors \"k8s.io/apimachinery/pkg/api/errors\"\n19\t\t\"k8s.io/apimachinery/pkg/api/resource\"\n20\t\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n21\t\t\"k8s.io/client-go/kubernetes\"\n22\t\n23\t\tpkg \"github.com/bborbe/agent-task-executor/pkg\"\n24\t)\n25\t\n26\t// taskIDLabelKey labels a spawned Job with the task UUID so IsJobActive\n27\t// can look it up. Must match the selector used in IsJobActive.\n28\tconst taskIDLabelKey = \"agent.benjamin-borbe.de/task-id\"\n29\t\n30\t//counterfeiter:generate -o ../../mocks/job_spawner.go --fake-name FakeJobSpawner . JobSpawner\n31\t\n32\t// JobSpawner creates a K8s Job for a task.\n33\ttype JobSpawner interface {\n34\t\t// SpawnJob creates a K8s Job for the task and returns the job name.\n35\t\t// Returns the job name even when the job already exists (idempotent).\n36\t\tSpawnJob(ctx context.Context, task lib.Task, config pkg.AgentConfiguration) (string, error)\n37\t\t// IsJobActive returns true if an active (not completed/failed) K8s Job exists\n38\t\t// for the given task identifier. Uses the agent.benjamin-borbe.de/task-id\n39\t\t// label set by SpawnJob.\n40\t\tIsJobActive(ctx context.Context, taskIdentifier lib.TaskIdentifier) (bool, error)\n41\t}\n42\t\n43\t// NewJobSpawner creates a new JobSpawner backed by the K8s batch/v1 API.\n44\t// jobTTLSecondsAfterFinished controls how long completed Job pods survive\n45\t// before Kubernetes' TTL controller garbage-collects them.\n46\tfunc NewJobSpawner(\n47\t\tkubeClient kubernetes.Interface,\n48\t\tnamespace k8s.Namespace,\n49\t\tkafkaBrokers string,\n50\t\tbranch string,\n51\t\ttopicPrefix string,\n52\t\tcurrentDateTimeGetter libtime.CurrentDateTimeGetter,\n53\t\tjobTTLSecondsAfterFinished int32,\n54\t) JobSpawner {\n55\t\treturn &jobSpawner{\n56\t\t\tkubeClient:                 kubeClient,\n57\t\t\tnamespace:                  namespace,\n58\t\t\tkafkaBrokers:               kafkaBrokers,\n59\t\t\tbranch:                     branch,\n60\t\t\ttopicPrefix:                topicPrefix,\n61\t\t\tcurrentDateTimeGetter:      currentDateTimeGetter,\n62\t\t\tjobTTLSecondsAfterFinished: jobTTLSecondsAfterFinished,\n63\t\t}\n64\t}\n65\t\n66\t// jobSpawner implements JobSpawner by creating batch/v1 Jobs via the K8s client.\n67\ttype jobSpawner struct {\n68\t\tkubeClient                 kubernetes.Interface\n69\t\tnamespace                  k8s.Namespace\n70\t\tkafkaBrokers               string\n71\t\tbranch                     string\n72\t\ttopicPrefix                string\n73\t\tcurrentDateTimeGetter      libtime.CurrentDateTimeGetter\n74\t\tjobTTLSecondsAfterFinished int32\n75\t}\n76\t\n77\tfunc (s *jobSpawner) SpawnJob(\n78\t\tctx context.Context,\n79\t\ttask lib.Task,\n80\t\tconfig pkg.AgentConfiguration,\n81\t) (string, error) {\n82\t\tassignee := task.Frontmatter.Assignee().String()\n83\t\tnow := s.currentDateTimeGetter.Now()\n84\t\tjobName := jobNameFromTask(assignee, task.TaskIdentifier, now)\n85\t\n86\t\tenvBuilder, err := s.buildJobEnvBuilder(ctx, task, config)\n87\t\tif err != nil {\n88\t\t\treturn \"\", err\n89\t\t}\n90\t\n91\t\tcontainerBuilder := k8s.NewContainerBuilder()\n92\t\tcontainerBuilder.SetName(k8s.Name(\"agent\"))\n93\t\tcontainerBuilder.SetImage(config.Image)\n94\t\tcontainerBuilder.SetEnvBuilder(envBuilder)\n95\t\tapplyCPUMemoryResources(config, containerBuilder)\n96\t\n97\t\tpodSpecBuilder := k8s.NewPodSpecBuilder()\n98\t\n99\t\tif err := applyVolumeMount(ctx, config, containerBuilder, podSpecBuilder); err != nil {\n100\t\t\treturn \"\", err\n101\t\t}\n102\t\n103\t\tcontainersBuilder := k8s.NewContainersBuilder()\n104\t\tcontainersBuilder.SetContainerBuilders([]k8s.HasBuildContainer{containerBuilder})\n105\t\n106\t\tpodSpecBuilder.SetContainersBuilder(containersBuilder)\n107\t\tpodSpecBuilder.SetRestartPolicy(corev1.RestartPolicyNever)\n108\t\tpodSpecBuilder.SetImagePullSecrets([]string{imagePullSecretName(config)})\n109\t\n110\t\tobjectMetaBuilder := k8s.NewObjectMetaBuilder()\n111\t\tobjectMetaBuilder.SetName(k8s.Name(jobName))\n112\t\tobjectMetaBuilder.SetNamespace(s.namespace)\n113\t\n114\t\tjobBuilder := k8s.NewJobBuilder()\n115\t\tjobBuilder.SetObjectMetaBuild(objectMetaBuilder)\n116\t\tjobBuilder.SetPodSpecBuilder(podSpecBuilder)\n117\t\tjobBuilder.SetBackoffLimit(0)\n118\t\tjobBuilder.SetTTLSecondsAfterFinished(s.jobTTLSecondsAfterFinished)\n119\t\tjobBuilder.SetApp(\"agent\")\n120\t\tjobBuilder.SetComponent(string(task.TaskIdentifier))\n121\t\n122\t\tjob, err := jobBuilder.Build(ctx)\n123\t\tif err != nil {\n124\t\t\treturn \"\", errors.Wrapf(ctx, err, \"build job for task %s\", task.TaskIdentifier)\n125\t\t}\n126\t\n127\t\tapplyTaskIDLabel(task.TaskIdentifier, job)\n128\t\tapplySecretEnvFrom(config, job)\n129\t\tapplyEphemeralStorage(config, job)\n130\t\tif config.PriorityClassName != \"\" {\n131\t\t\tjob.Spec.Template.Spec.PriorityClassName = config.PriorityClassName\n132\t\t}\n133\t\tapplyActiveDeadlineSeconds(config, jobName, task.TaskIdentifier, job)\n134\t\n135\t\t_, err = s.kubeClient.BatchV1().\n136\t\t\tJobs(s.namespace.String()).\n137\t\t\tCreate(ctx, job, metav1.CreateOptions{})\n138\t\tif err != nil {\n139\t\t\tif k8serrors.IsAlreadyExists(err) {\n140\t\t\t\tglog.V(2).\n141\t\t\t\t\tInfof(\"job %s already exists for task %s, treating as success\", jobName, task.TaskIdentifier)\n142\t\t\t\treturn jobName, nil\n143\t\t\t}\n144\t\t\treturn \"\", errors.Wrapf(\n145\t\t\t\tctx,\n146\t\t\t\terr,\n147\t\t\t\t\"create job %s for task %s failed\",\n148\t\t\t\tjobName,\n149\t\t\t\ttask.TaskIdentifier,\n150\t\t\t)\n151\t\t}\n152\t\tglog.V(2).\n153\t\t\tInfof(\"created job %s for task %s with image %s\", jobName, task.TaskIdentifier, config.Image)\n154\t\treturn jobName, nil\n155\t}\n156\t\n157\tfunc (s *jobSpawner) IsJobActive(\n158\t\tctx context.Context,\n159\t\ttaskIdentifier lib.TaskIdentifier,\n160\t) (bool, error) {\n161\t\tlabelSelector := taskIDLabelKey + \"=\" + string(taskIdentifier)\n162\t\tjobs, err := s.kubeClient.BatchV1().Jobs(s.namespace.String()).List(ctx, metav1.ListOptions{\n163\t\t\tLabelSelector: labelSelector,\n164\t\t})\n165\t\tif err != nil {\n166\t\t\treturn false, errors.Wrapf(ctx, err, \"list jobs for task %s\", taskIdentifier)\n167\t\t}\n168\t\tfor _, job := range jobs.Items {\n169\t\t\tif job.Status.Succeeded > 0 {\n170\t\t\t\tcontinue\n171\t\t\t}\n172\t\t\tif job.Status.Failed > 0 && job.Status.Active == 0 {\n173\t\t\t\tcontinue\n174\t\t\t}\n175\t\t\treturn true, nil\n176\t\t}\n177\t\treturn false, nil\n178\t}\n179\t\n180\t// applyVolumeMount configures a PVC volume mount on the container and pod spec builders\n181\t// when config.VolumeClaim is non-empty. Returns an error if VolumeMountPath is missing.\n182\tfunc applyVolumeMount(\n183\t\tctx context.Context,\n184\t\tconfig pkg.AgentConfiguration,\n185\t\tcontainerBuilder k8s.ContainerBuilder,\n186\t\tpodSpecBuilder k8s.PodSpecBuilder,\n187\t) error {\n188\t\tif config.VolumeClaim == \"\" {\n189\t\t\treturn nil\n190\t\t}\n191\t\tif config.VolumeMountPath == \"\" {\n192\t\t\treturn errors.Errorf(ctx, \"VolumeMountPath required when VolumeClaim is set\")\n193\t\t}\n194\t\tcontainerBuilder.AddVolumeMounts(corev1.VolumeMount{\n195\t\t\tName:      \"agent-data\",\n196\t\t\tMountPath: config.VolumeMountPath,\n197\t\t})\n198\t\tpodSpecBuilder.SetVolumes([]corev1.Volume{\n199\t\t\t{\n200\t\t\t\tName: \"agent-data\",\n201\t\t\t\tVolumeSource: corev1.VolumeSource{\n202\t\t\t\t\tPersistentVolumeClaim: &corev1.PersistentVolumeClaimVolumeSource{\n203\t\t\t\t\t\tClaimName: config.VolumeClaim,\n204\t\t\t\t\t},\n205\t\t\t\t},\n206\t\t\t},\n207\t\t})\n208\t\treturn nil\n209\t}\n210\t\n211\t// imagePullSecretName returns the image pull secret name from the config,\n212\t// falling back to \"docker\" when not set.\n213\tfunc imagePullSecretName(config pkg.AgentConfiguration) string {\n214\t\tif config.ImagePullSecret != \"\" {\n215\t\t\treturn config.ImagePullSecret\n216\t\t}\n217\t\treturn \"docker\"\n218\t}\n219\t\n220\t// applyCPUMemoryResources sets CPU and memory requests/limits on the container builder\n221\t// when the corresponding config values are non-empty. Empty values leave builder defaults untouched.\n222\tfunc applyCPUMemoryResources(config pkg.AgentConfiguration, containerBuilder k8s.ContainerBuilder) {\n223\t\tif config.Resources == nil {\n224\t\t\treturn\n225\t\t}\n226\t\tif v := config.Resources.Requests.CPU; v != \"\" {\n227\t\t\tcontainerBuilder.SetCpuRequest(v)\n228\t\t}\n229\t\tif v := config.Resources.Limits.CPU; v != \"\" {\n230\t\t\tcontainerBuilder.SetCpuLimit(v)\n231\t\t}\n232\t\tif v := config.Resources.Requests.Memory; v != \"\" {\n233\t\t\tcontainerBuilder.SetMemoryRequest(v)\n234\t\t}\n235\t\tif v := config.Resources.Limits.Memory; v != \"\" {\n236\t\t\tcontainerBuilder.SetMemoryLimit(v)\n237\t\t}\n238\t}\n239\t\n240\t// applySecretEnvFrom appends an envFrom secretRef to the first container of the job\n241\t// when config.SecretName is non-empty.\n242\tfunc applySecretEnvFrom(config pkg.AgentConfiguration, job *batchv1.Job) {\n243\t\tif config.SecretName == \"\" {\n244\t\t\treturn\n245\t\t}\n246\t\tjob.Spec.Template.Spec.Containers[0].EnvFrom = append(\n247\t\t\tjob.Spec.Template.Spec.Containers[0].EnvFrom,\n248\t\t\tcorev1.EnvFromSource{\n249\t\t\t\tSecretRef: &corev1.SecretEnvSource{\n250\t\t\t\t\tLocalObjectReference: corev1.LocalO