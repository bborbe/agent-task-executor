{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HRAxcwutEAwiSYHMYAy8ZV","type":"tool_result","content":"1\t// Copyright (c) 2026 Benjamin Borbe All rights reserved.\n2\t// Use of this source code is governed by a BSD-style\n3\t// license that can be found in the LICENSE file.\n4\t\n5\tpackage factory\n6\t\n7\timport (\n8\t\t\"context\"\n9\t\n10\t\t\"github.com/IBM/sarama\"\n11\t\tlib \"github.com/bborbe/agent\"\n12\t\t\"github.com/bborbe/cqrs/base\"\n13\t\tcdb \"github.com/bborbe/cqrs/cdb\"\n14\t\tlibcron \"github.com/bborbe/cron\"\n15\t\tlibk8s \"github.com/bborbe/k8s\"\n16\t\tlibkafka \"github.com/bborbe/kafka\"\n17\t\t\"github.com/bborbe/log\"\n18\t\t\"github.com/bborbe/run\"\n19\t\tlibtime \"github.com/bborbe/time\"\n20\t\t\"k8s.io/client-go/kubernetes\"\n21\t\t\"k8s.io/client-go/rest\"\n22\t\t\"k8s.io/client-go/tools/cache\"\n23\t\n24\t\tpkg \"github.com/bborbe/agent-task-executor/pkg\"\n25\t\t\"github.com/bborbe/agent-task-executor/pkg/handler\"\n26\t\t\"github.com/bborbe/agent-task-executor/pkg/probe\"\n27\t\t\"github.com/bborbe/agent-task-executor/pkg/spawner\"\n28\t)\n29\t\n30\t// CreateJobWatcher creates a JobWatcher that reacts to terminal batch/v1 Job states.\n31\tfunc CreateJobWatcher(\n32\t\tkubeClient kubernetes.Interface,\n33\t\tnamespace libk8s.Namespace,\n34\t\ttaskStore *pkg.TaskStore,\n35\t\tpublisher pkg.ResultPublisher,\n36\t) pkg.JobWatcher {\n37\t\treturn pkg.NewJobWatcher(kubeClient, namespace, taskStore, publisher)\n38\t}\n39\t\n40\t// CreateZombieSweeper creates a deadline sweeper that classifies stuck tasks as\n41\t// zombies and emits failure events via the publisher. Interval and per-task\n42\t// deadline are sourced from the AgentConfig CRD knobs (see ConfigSpec). The\n43\t// sweeper receives the JobWatcher (not its lister) because the lister is\n44\t// populated only after JobWatcher.Run completes its informer cache sync; passing\n45\t// the watcher lets the sweeper resolve the lister lazily on each tick and