DIRS += $(shell find */* -maxdepth 0 -name Makefile -exec dirname "{}" \;)

.PHONY: build
build: check-go-mod
	DOCKER_BUILDKIT=1 \
	docker build \
	--pull \
	--no-cache \
	--rm=true \
	--platform=linux/amd64 \
	--build-arg DOCKER_REGISTRY=$(DOCKER_REGISTRY) \
	--build-arg BRANCH=$(BRANCH) \
	--build-arg BUILD_GIT_COMMIT=$$(git rev-parse --short HEAD) \
	--build-arg BUILD_DATE=$$(date -u +%Y-%m-%dT%H:%M:%SZ) \
	-t $(DOCKER_REGISTRY)/$(SERVICE):$(BRANCH) \
	-f Dockerfile .

.PHONY: check-go-mod
check-go-mod:
	@if [ -f "go.mod" ]; then \
		echo "go.mod found, running go mod vendor..."; \
		go mod vendor; \
	else \
		echo "go.mod not found, skipping go mod vendor."; \
	fi

.PHONY: upload
upload:
	docker push $(DOCKER_REGISTRY)/$(SERVICE):$(BRANCH)

.PHONY: clean
clean:
	docker rmi $(DOCKER_REGISTRY)/$(SERVICE):$(BRANCH) || true
	docker image prune -f || true
	docker builder prune --all -f || true
	rm -rf vendor

.PHONY: apply
apply:
	@for i in $(DIRS); do \
		cd $$i; \
		echo "apply $${i}"; \
		make apply; \
		cd ..; \
	done

.PHONY: buca
buca: build upload clean apply

# Public release — build + push a semver-tagged image to Docker Hub.
# Additive and independent of the private-registry buca flow: common.env
# force-sets DOCKER_REGISTRY to the quant registry, so this target uses its own
# PUBLIC_* vars. VERSION comes from the latest git tag (cut by the maintainer
# release bot). Pattern mirrors bborbe/kafka-topic-reader. Run after a tag exists;
# requires `docker login` to Docker Hub.
PUBLIC_REGISTRY ?= docker.io
PUBLIC_IMAGE ?= bborbe/$(SERVICE)
VERSION ?= $(shell git describe --tags `git rev-list --tags --max-count=1`)

.PHONY: publish
publish: check-go-mod
	DOCKER_BUILDKIT=1 \
	docker build \
	--pull \
	--no-cache \
	--rm=true \
	--platform=linux/amd64 \
	--build-arg DOCKER_REGISTRY=$(PUBLIC_REGISTRY) \
	--build-arg BUILD_GIT_VERSION=$(VERSION) \
	--build-arg BUILD_GIT_COMMIT=$$(git rev-parse --short HEAD) \
	--build-arg BUILD_DATE=$$(date -u +%Y-%m-%dT%H:%M:%SZ) \
	-t $(PUBLIC_REGISTRY)/$(PUBLIC_IMAGE):$(VERSION) \
	-f Dockerfile .
	docker push $(PUBLIC_REGISTRY)/$(PUBLIC_IMAGE):$(VERSION)
	docker rmi $(PUBLIC_REGISTRY)/$(PUBLIC_IMAGE):$(VERSION) || true
	rm -rf vendor
